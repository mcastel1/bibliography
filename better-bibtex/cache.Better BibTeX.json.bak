uthor = {Poincar{\\'e}, H.},\n  edition = {1905},\n  volume = {1},\n  publisher = {{Gauthier-Villars}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256446,"version":0,"updated":1753730283776},"$loki":1789},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26312,"entry":"@incollection{poincareMethodesNouvellesMecanique1892,\n  title = {Les M{\\'e}thodes Nouvelles de La M{\\'e}canique C{\\'e}leste},\n  author = {Poincar{\\'e}, H.},\n  year = {1892},\n  volume = {1},\n  publisher = {{Gauthier-Villars}},\n  chapter = {1}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256446,"version":0,"updated":1753730283776},"$loki":1790},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26596,"entry":"@incollection{poincareOEuvres1952,\n  title = {{{{\\O}Euvres}}},\n  author = {Poincar{\\'e}, H},\n  year = {1952},\n  volume = {VII},\n  pages = {496--498},\n  publisher = {{Gauthier-Villars}},\n  chapter = {24}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256446,"version":0,"updated":1753730283776},"$loki":1791},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26225,"entry":"@article{polyakovInteractionGoldstoneParticles1975,\n  title = {Interaction of {{Goldstone}} Particles in Two Dimensions. {{Applications}} to Ferromagnets and Massive {{Yang-Mills}} Fields},\n  author = {Polyakov, A. M.},\n  year = {1975},\n  journal = {Physics Letters B},\n  volume = {59},\n  number = {1},\n  pages = {79--81},\n  issn = {0370-2693}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256447,"version":0,"updated":1753730283776},"$loki":1792},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25867,"entry":"@book{pooleComputationalIntelligenceLogical1998,\n  title = {Computational {{Intelligence}}: {{A Logical Approach}}},\n  author = {Poole, D. and Mackworth, A. and Goebel, R.},\n  year = {1998},\n  publisher = {{Oxford University Press Press}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256448,"version":0,"updated":1753730283776},"$loki":1793},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26501,"entry":"@article{pooreMultidimensionalAssignmentFormulation1994,\n  title = {Multidimensional Assignment Formulation of Data Association Problems Arising from Multitarget and Multisensor Tracking},\n  author = {Poore, A. B.},\n  year = {1994},\n  journal = {Comput. Opt. Appl.},\n  volume = {3},\n  pages = {27--54}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256449,"version":0,"updated":1753730283776},"$loki":1794},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26033,"entry":"@article{potelEWI2wintPromotesCD812013,\n  title = {{{EWI-2wint}} Promotes {{CD81}} Clustering That Abrogates {{Hepatitis C Virus}} Entry},\n  author = {Potel, J. and Rassam, P. and Montpellier, C. and Kaestner, L. and Werkmeister, E. and Tews, B. A. and Couturier, C. and Popescu, C.-I. and Baumert, T. F. and Rubinstein, E. and Dubuisson, J. and E, Milhiet P. and Cocquerel, L.},\n  year = {2013},\n  journal = {Cell. Microbiol.},\n  volume = {17},\n  number = {7},\n  pages = {1234},\n  publisher = {{Wiley Online Library}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256450,"version":0,"updated":1753730283776},"$loki":1795},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26914,"entry":"@book{pozrikidis1992boundary,\n  title = {Boundary Integral and Singularity Methods for Linearized Viscous Flow},\n  author = {Pozrikidis, Constantine},\n  year = {1992},\n  publisher = {{Cambridge university press}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256450,"version":0,"updated":1753730283776},"$loki":1796},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25731,"entry":"@book{pozrikidisIntroductionGridsGraphs2014,\n  title = {An {{Introduction}} to {{Grids}}, {{Graphs}}, and {{Networks}}},\n  author = {Pozrikidis, C.},\n  year = {2014},\n  publisher = {{Oxford University Press}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256450,"version":0,"updated":1753730283776},"$loki":1797},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26477,"entry":"@article{prescottModifiedMethodsDetermination1969,\n  title = {Modified Methods for the Determination of Carbamyl Aspartate},\n  author = {Prescott, L. M. and Jones, M. E.},\n  year = {1969},\n  journal = {Anal. Biochem.},\n  volume = {32},\n  number = {3},\n  pages = {408}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256451,"version":0,"updated":1753730283776},"$loki":1798},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26583,"entry":"@book{pressNumericalRecipes3rd2007,\n  title = {Numerical {{Recipes}} 3rd {{Edition}}: {{The Art}} of {{Scientific Computing}}},\n  author = {Press, W. H. and Teukolsky, S. A. and Vetterling, W. T. and Flannery, B. P.},\n  year = {2007},\n  month = sep,\n  edition = {3},\n  publisher = {{Cambridge University Press}},\n  abstract = {Co-authored by four leading scientists from academia and industry, Numerical Recipes Third Edition starts with basic mathematics and computer science and proceeds to complete, working routines. Widely recognized as the most comprehensive, accessible and practical basis for scientific computing, this new edition incorporates more than 400 Numerical Recipes routines, many of them new or upgraded. The executable C++ code, now printed in color for easy reading, adopts an object-oriented style particularly suited to scientific applications. The whole book is presented in the informal, easy-to-read style that made earlier editions so popular. New key features: 2 new chapters, 25 new sections, 25\\% longer than Second Edition; Thorough upgrades throughout the text; Over 100 completely new routines and upgrades of many more; New Classification and Inference chapter, including Gaussian mixture models, HMMs, hierarchical clustering, Support Vector Machines; New Computational Geometry chapter covers KD trees, quad- and octrees, Delaunay triangulation, and algorithms for lines, polygons, triangles, and spheres; New sections include interior point methods for linear programming, Monte Carlo Markov Chains, spectral and pseudospectral methods for PDEs, and many new statistical distributions; An expanded treatment of ODEs with completely new routines; Comprehensive coverage of: linear algebra, interpolation, special functions, random numbers, nonlinear sets of equations, optimization, eigensystems, Fourier methods and wavelets, statistical tests, ODEs and PDEs, integral equations, and inverse theory, and more. - Publisher.},\n  isbn = {0-521-88068-8},\n  keywords = {2007,c,numerical,recipes}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256452,"version":0,"updated":1753730283776},"$loki":1799},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26850,"entry":"@article{prostFluctuationmagnificationNonequilibriumMembranes1998,\n  title = {Fluctuation-Magnification of Non-Equilibrium Membranes near a Wall},\n  author = {Prost, J. and Manneville, J.-B. and Bruinsma, R.},\n  year = {1998},\n  month = mar,\n  journal = {Eur. Phys. J. B},\n  volume = {1},\n  number = {4},\n  pages = {465--480},\n  issn = {1434-6028},\n  doi = {10.1007/s100510050209},\n  urldate = {2025-06-01},\n  abstract = {Membranes in thermal equilibrium are well known to exhibit Brownian motion type shape fluctuations. Membranes containing active force centers {\\textemdash} such as chemically active membrane proteins {\\textemdash}suffer additional non-equilibrium shape fluctuations due to the activity of these force centers. We demonstrate, using scaling arguments, that non-equilibrium shape fluctuations are in general greatly amplified by the presence of a nearby wall or membrane due to the absence of a fluctuation-dissipation theorem. For adhesive membranes, this fluctuation magnification effect may facilitate the establishment of bonding. For non-adhesive membranes, fluctuation magnification produces a long-range repulsive pressure which can exceed the well known Helfrich repulsion due to purely thermal fluctuations.},\n  copyright = {http://www.springer.com/tdm},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/XL83RAM7/Prost et al. - 1998 - Fluctuation-magnification of non-equilibrium membr.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256453,"version":0,"updated":1753730283776},"$loki":1800},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26848,"entry":"@article{prostShapeFluctuationsActive1996,\n  title = {Shape Fluctuations of Active Membranes},\n  author = {Prost, J and Bruinsma, R},\n  year = {1996},\n  month = feb,\n  journal = {Europhys. Lett.},\n  volume = {33},\n  number = {4},\n  pages = {321--326},\n  issn = {0295-5075, 1286-4854},\n  doi = {10.1209/epl/i1996-00340-1},\n  urldate = {2025-06-01},\n  abstract = {We present a simple model to study the statistical fluctuations of membranes containing active proteins. We show that the long-wavelenght limit of the shape fluctuation spectrum of active membranes diverges with a power law which is different from that of membranes in thermal equilibrium. This leads to a persistence length for active membranes which is much shorter than that of equilibrium membranes.},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/KLTR8IEA/Prost and Bruinsma - 1996 - Shape fluctuations of active membranes.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256453,"version":0,"updated":1753730283776},"$loki":1801},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25673,"entry":"@article{ptacinSpindlelikeApparatusGuides2010,\n  title = {A Spindle-like Apparatus Guides Bacterial Chromosome Segregation},\n  author = {Ptacin, J. L. and Lee, S. F. and Garner, E. C. and Toro, E. and Eckart, M. and Comolli, L. R. and Moerner, W. E. and Shapiro, L.},\n  year = {2010},\n  journal = {Nat. Cell. Biol.},\n  volume = {12},\n  number = {8},\n  pages = {791}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256453,"version":0,"updated":1753730283776},"$loki":1802},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26897,"entry":"@incollection{Pugh_2016,\n  title = {Soap Bubbles and Thin Films},\n  booktitle = {Bubble and Foam Chemistry},\n  author = {Pugh, Robert J.},\n  year = {2016},\n  pages = {84--111},\n  publisher = {{Cambridge University Press}},\n  address = {{Cambridge}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256454,"version":0,"updated":1753730283776},"$loki":1803},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26896,"entry":"@book{pughBubbleFoamChemistry2016,\n  title = {Bubble and {{Foam Chemistry}}},\n  author = {Pugh, Robert J.},\n  year = {2016},\n  month = jul,\n  edition = {1},\n  publisher = {{Cambridge University Press}},\n  doi = {10.1017/CBO9781316106938},\n  urldate = {2025-06-16},\n  abstract = {This indispensable guide will equip the reader with a thorough understanding of the field of foaming chemistry. Assuming only basic theoretical background knowledge, the book provides a straightforward introduction to the principles and properties of foams and foaming surfactants. It discusses the key ideas that underpin why foaming occurs, how it can be avoided and how different degrees of antifoaming can be achieved, and covers the latest test methods, including laboratory and industrial developed techniques. Detailing a variety of different kinds of foams, from wet detergents and food foams, to polymeric, material and metal foams, it connects theory to real-world applications and recent developments in foam research. Combining academic and industrial viewpoints, this book is the definitive stand-alone resource for researchers, students and industrialists working on foam technology, colloidal systems in the field of chemical engineering, fluid mechanics, physical chemistry, and applied physics.},\n  copyright = {https://www.cambridge.org/core/terms},\n  isbn = {978-1-107-09057-6 978-1-316-10693-8}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256454,"version":0,"updated":1753730283776},"$loki":1804},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26846,"entry":"@article{quemeneurShapeMattersProtein2014,\n  title = {Shape Matters in Protein Mobility within Membranes},\n  author = {Quemeneur, Fran{\\c c}ois and Sigurdsson, Jon K. and Renner, Marianne and Atzberger, Paul J. and Bassereau, Patricia and Lacoste, David},\n  year = {2014},\n  month = apr,\n  journal = {Proc. Natl. Acad. Sci. U.S.A.},\n  volume = {111},\n  number = {14},\n  pages = {5083--5087},\n  issn = {0027-8424, 1091-6490},\n  doi = {10.1073/pnas.1321054111},\n  urldate = {2025-06-01},\n  abstract = {Significance             Lateral Brownian diffusion of proteins in lipid membranes has been predicted by Saffman and Delbr{\\\"u}ck to depend only on protein size and on the viscosity of the membrane and of the surrounding medium. Using a single-molecule tracking technique on two transmembrane proteins that bend the membrane differently and are reconstituted in giant unilamellar vesicles, we show that the mobility of a membrane protein is crucially dependent on the local membrane deformation self-generated around the protein, which can be tuned by adjusting membrane tension. The feedback between membrane shaping and mobility is well explained by analytical and numerical models that include the friction of the deformed membrane patch with the surrounding medium and the friction internal to the bilayer.           ,              The lateral mobility of proteins within cell membranes is usually thought to be dependent on their size and modulated by local heterogeneities of the membrane. Experiments using single-particle tracking on reconstituted membranes demonstrate that protein diffusion is significantly influenced by the interplay of membrane curvature, membrane tension, and protein shape. We find that the curvature-coupled voltage-gated potassium channel (KvAP) undergoes a significant increase in protein mobility under tension, whereas the mobility of the curvature-neutral water channel aquaporin 0 (AQP0) is insensitive to it. Such observations are well explained in terms of an effective friction coefficient of the protein induced by the local membrane deformation.},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/69X8IUMQ/Quemeneur et al. - 2014 - Shape matters in protein mobility within membranes.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256456,"version":0,"updated":1753730283776},"$loki":1805},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26889,"entry":"@article{rahimi2021,\n  title = {Curved Fluid Membranes Behave Laterally as Effective Viscoelastic Media},\n  author = {Rahimi, Mohammad and Arroyo, Marino and Stone, Howard A.},\n  year = {2021},\n  journal = {Soft Matter},\n  volume = {17},\n  number = {3},\n  pages = {744--755},\n  publisher = {{Royal Society of Chemistry}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256456,"version":0,"updated":1753730283776},"$loki":1806},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26910,"entry":"@article{ramaswamy2000nonequilibrium,\n  title = {Nonequilibrium Fluctuations, Traveling Waves, and Instabilities in Active Membranes},\n  author = {Ramaswamy, Sriram and Toner, John and Prost, Jacques},\n  year = {2000},\n  journal = {Physical review letters},\n  volume = {84},\n  number = {15},\n  pages = {3494},\n  publisher = {{APS}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256457,"version":0,"updated":1753730283776},"$loki":1807},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26563,"entry":"@article{ramaswamyNonequilibriumFluctuationsTraveling2000,\n  title = {Nonequilibrium {{Fluctuations}}, {{Traveling Waves}}, and {{Instabilities}} in {{Active Membranes}}},\n  author = {Ramaswamy, Sriram and Toner, John and Prost, Jacques},\n  year = {2000},\n  month = apr,\n  journal = {Phys. Rev. Lett.},\n  volume = {84},\n  number = {15},\n  pages = {3494--3497},\n  issn = {0031-9007, 1079-7114},\n  doi = {10.1103/PhysRevLett.84.3494},\n  urldate = {2025-03-31},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/NHWVEB2B/Ramaswamy et al. - 2000 - Nonequilibrium Fluctuations, Traveling Waves, and .pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256457,"version":0,"updated":1753730283776},"$loki":1808},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26781,"entry":"@article{ramaswamyNonequilibriumNoiseInstabilities1999,\n  title = {Nonequilibrium Noise and Instabilities in Membranes with Active Pumps},\n  author = {Ramaswamy, Sriram and Toner, John and Prost, Jacques},\n  year = {1999},\n  month = jul,\n  journal = {Pramana - J Phys},\n  volume = {53},\n  number = {1},\n  pages = {237--242},\n  issn = {0304-4289, 0973-7111},\n  doi = {10.1007/s12043-999-0152-2},\n  urldate = {2025-05-08},\n  abstract = {We study the statistical properties and dynamics of flexible fluid membranes containing active transmembrane proteins and find that such active membranes can be either stable or unstable to small disturbances, depending on the signs of certain crucial parameters characterising the protein-membrane interaction. A major finding is that the shape-fluctuation spectrum in the stable case for a zero-tension active membrane has the same form over a large range of length scales as at equilibrium, but with a nonequilibrium ``noise temperature'' determined by the activity.},\n  copyright = {http://www.springer.com/tdm},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/LLPUPFZE/Ramaswamy et al. - 1999 - Nonequilibrium noise and instabilities in membrane.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256458,"version":0,"updated":1753730283776},"$loki":1809},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26634,"entry":"@article{rammalDegreeUltrametricity1985,\n  title = {On the {{Degree}} of {{Ultrametricity}}},\n  author = {Rammal, R. and {d'Auriac}, J.-C. Angles and Doucot, B.},\n  year = {1985},\n  journal = {J. Physique Lett.},\n  volume = {46},\n  pages = {L945--L952}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256458,"version":0,"updated":1753730283776},"$loki":1810},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26779,"entry":"@article{raucherCharacteristicsMembraneReservoir1999,\n  title = {Characteristics of a {{Membrane Reservoir Buffering Membrane Tension}}},\n  author = {Raucher, Drazen and Sheetz, Michael P.},\n  year = {1999},\n  month = oct,\n  journal = {Biophysical Journal},\n  volume = {77},\n  number = {4},\n  pages = {1992--2002},\n  issn = {00063495},\n  doi = {10.1016/S0006-3495(99)77040-2},\n  urldate = {2025-05-08},\n  abstract = {When membrane-attached beads are pulled vertically by a laser tweezers, a membrane tube of constant diameter (tether) is formed. We found that the force on the bead (tether force) did not depend on tether length over a wide range of tether lengths, which indicates that a previously unidentified reservoir of membrane and not stretch of the plasma membrane provides the tether membrane. Plots of tether force vs. tether length have an initial phase, an elongation phase, and an exponential phase. During the major elongation phase, tether force is constant, buffered by the ``membrane reservoir.'' Finally, there is an abrupt exponential rise in force that brings the tether out of the trap, indicating depletion of the membrane reservoir. In chick embryo fibroblasts and 3T3 fibroblasts, the maximum tether lengths that can be pulled at a velocity of 4 ␮m/s are 5.1 Ϯ 0.3 and 5.0 Ϯ 0.2 ␮m, respectively. To examine the importance of the actin cytoskeleton, we treated cells with cytochalasin B or D and found that the tether lengths increased dramatically to 13.8 Ϯ 0.8 and 12.0 Ϯ 0.7 ␮m, respectively. Similarly, treatment of the cells with colchicine and nocodazole results in more than a twofold increase in tether length. We found that elevation of membrane tension (through osmotic pressure, a long-term elevation of tether force, or a number of transitory increases) increased reservoir size over the whole cell. Using a tracking system to hold tether force on the bead constant near its maximal length in the exponential phase, the rate of elongation of the tethers was measured as a function of tether force (membrane tension). The rate of elongation of tethers was linearly dependent on the tether force and reflected an increase in size of the reservoir. Increases in the reservoir caused by tension increases on one side of the cell caused increases in reservoir size on the other side of the cell. Thus, we suggest that cells maintain a plasma membrane reservoir to buffer against changes in membrane tension and that the reservoir is increased with membrane tension or disruption of the cytoskeleton.},\n  copyright = {https://www.elsevier.com/tdm/userlicense/1.0/},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/RRVMDDXB/Raucher and Sheetz - 1999 - Characteristics of a Membrane Reservoir Buffering .pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256461,"version":0,"updated":1753730283776},"$loki":1811},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26127,"entry":"@misc{reallGeneralRelativity,\n  title = {General {{Relativity}}},\n  author = {Reall, H.},\n  howpublished = {https://www.damtp.cam.ac.uk/user/hsr1000/teaching.html},\n  file = {/Users/michelecastellana/Zotero/storage/B3QQAF3T/Reall - General Relativity.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256461,"version":0,"updated":1753730283776},"$loki":1812},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25733,"entry":"@book{reddyIntroductionFiniteElement2006,\n  title = {An Introduction to the Finite Element Method},\n  author = {Reddy, J. N.},\n  year = {2006},\n  publisher = {{McGraw-Hill}},\n  address = {{Boston}},\n  langid = {english}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256461,"version":0,"updated":1753730283776},"$loki":1813},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26503,"entry":"@article{reedMultienzymeComplexes1974,\n  title = {Multienzyme Complexes},\n  author = {Reed, L. J.},\n  year = {1974},\n  journal = {Accounts Chem. Res.},\n  volume = {7},\n  number = {2},\n  pages = {40}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256461,"version":0,"updated":1753730283776},"$loki":1814},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26475,"entry":"@book{reevesModernHeuristicTechniques1993,\n  title = {Modern {{Heuristic Techniques}} for {{Combinatorial Problems}}},\n  author = {Reeves, C. R.},\n  year = {1993},\n  publisher = {{Halsted Press}},\n  address = {{New York}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256462,"version":0,"updated":1753730283776},"$loki":1815},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26222,"entry":"@misc{reindersIntelAVX5122017,\n  title = {{{Intel}}{\\textregistered} \\{\\vphantom\\}{{AVX}}\\vphantom\\{\\}-512 \\{\\vphantom\\}{{I}}\\vphantom\\{\\}nstructions},\n  author = {Reinders, J. R.},\n  year = {2017}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":["textcomp"]},"meta":{"revision":0,"created":1751534256462,"version":0,"updated":1753730283776},"$loki":1816},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26223,"entry":"@misc{reindersIntelAVX512Instructions2017,\n  title = {{{Intel}}{\\textregistered} {{AVX-512 Instructions}}},\n  author = {Reinders, J. R.},\n  year = {2017}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":["textcomp"]},"meta":{"revision":0,"created":1751534256462,"version":0,"updated":1753730283776},"$loki":1817},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26892,"entry":"@article{reuther2023,\n  title = {Modeling and Simulation of Membrane Proteins and Protein-Induced Membrane Deformations},\n  author = {Reuther, Christian and Rangamani, Padmini and Arroyo, Marino},\n  year = {2023},\n  journal = {Annual Review of Condensed Matter Physics},\n  volume = {14},\n  pages = {209--234},\n  publisher = {{Annual Reviews}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256463,"version":0,"updated":1753730283776},"$loki":1818},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26082,"entry":"@incollection{reynoldsFlocksHerdsSchools,\n  title = {Flocks, Herds, and Schools: {{A}} Distributed Behavioral Model},\n  author = {Reynolds, C. W.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256463,"version":0,"updated":1753730283776},"$loki":1819},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25690,"entry":"@article{ricci-tersenghiAbsenceAgingRemanent2000,\n  title = {Absence of Aging in the Remanent Magnetization in {{Migdal-Kadanoff}} Spin Glasses},\n  author = {{Ricci-Tersenghi}, F. and Ritort, F.},\n  year = {2000},\n  journal = {J. Phys. A},\n  volume = {33},\n  pages = {3727}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256463,"version":0,"updated":1753730283776},"$loki":1820},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26628,"entry":"@article{ricci-tersenghiCavityMethodDecimated2009,\n  title = {On the Cavity Method for Decimated Random Constraint Satisfaction Problems and the Analysis of Belief Propagation Guided Decimation Algorithms},\n  author = {{Ricci-Tersenghi}, F. and Semerjian, G.},\n  year = {2009},\n  journal = {J. Stat. Mech.},\n  pages = {P09001}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256464,"version":0,"updated":1753730283776},"$loki":1821},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25935,"entry":"@article{richardsonDesignCapacityapproachingIrregular2001,\n  title = {Design of Capacity-Approaching Irregular Low-Density Parity-Check Codes},\n  author = {Richardson, T. J. and Shokrollahi, M. A. and Urbanke, R. L.},\n  year = {2001},\n  journal = {IEEE Trans. Inform. Theory},\n  volume = {47},\n  pages = {619--637}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256464,"version":0,"updated":1753730283776},"$loki":1822},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26474,"entry":"@book{richardsonModernCodingTheory2007,\n  title = {Modern {{Coding Theory}}},\n  author = {Richardson, T. and Urbanke, R.},\n  year = {2007},\n  publisher = {{Cambridge University Press}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256464,"version":0,"updated":1753730283776},"$loki":1823},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25970,"entry":"@article{richertDynamicsGlassformingLiquids1998,\n  title = {Dynamics of Glass-Forming Liquids. {{V}}. {{On}} the Link between Molecular Dynamics and Configurational Entropy},\n  author = {Richert, R. and Angell, {\\relax CA}},\n  year = {1998},\n  journal = {The Journal of Chemical Physics},\n  volume = {108},\n  pages = {9016}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256465,"version":0,"updated":1753730283776},"$loki":1824},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26121,"entry":"@incollection{riegerFrustratedSystemsGround1998,\n  title = {Frustrated {{Systems}}: {{Ground State Properties}} via {{Combinatorial Optimization}}},\n  booktitle = {Advances in {{Computer Simulation}}},\n  author = {Rieger, H.},\n  editor = {Kertesz, J. and Kondor, I.},\n  year = {1998},\n  series = {Lecture {{Notes}} in {{Physics}}},\n  volume = {501},\n  publisher = {{Springer-Verlag}},\n  address = {{Heidelberg}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256465,"version":0,"updated":1753730283776},"$loki":1825},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26494,"entry":"@incollection{riegerMonteCarloStudies1995,\n  title = {Monte {{Carlo Studies}} of {{Ising Spin Glasses}} and {{Random Field Systems}}},\n  booktitle = {Annual {{Reviews}} of {{Computational Physics II}}},\n  author = {Rieger, H.},\n  editor = {Stauffer, D.},\n  year = {1995},\n  publisher = {{World Scientific}},\n  address = {{Singapore}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256466,"version":0,"updated":1753730283776},"$loki":1826},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26553,"entry":"@article{riegerNonequilibriumDynamicsAging1993,\n  title = {Non-Equilibrium {{Dynamics}} and {{Aging}} in the {{Three-Dimensional Ising Spin-Glass Model}}},\n  author = {Rieger, H.},\n  year = {1993},\n  journal = {J. Phys. A Lett.},\n  volume = {26},\n  pages = {L615--L621}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256467,"version":0,"updated":1753730283776},"$loki":1827},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26151,"entry":"@article{ritortGlassyDynamicsKinetically2003,\n  title = {Glassy Dynamics of Kinetically Constrained Models},\n  author = {Ritort, F. and Sollich, P.},\n  year = {2003},\n  journal = {Adv. Phys.},\n  volume = {52},\n  pages = {219--342}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256467,"version":0,"updated":1753730283776},"$loki":1828},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26040,"entry":"@article{rivoireExactlySolvableModels2006,\n  title = {Exactly {{Solvable Models}} of {{Adaptive Networks}}},\n  author = {Rivoire, O. and Barr{\\'e}, J.},\n  year = {2006},\n  month = oct,\n  journal = {Phys. Rev. Lett.},\n  volume = {97},\n  number = {14},\n  pages = {148701},\n  doi = {10.1103/PhysRevLett.97.148701}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256468,"version":0,"updated":1753730283776},"$loki":1829},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26148,"entry":"@article{rivoireGlassModelsBethe2004,\n  title = {Glass Models on {{Bethe}} Lattices},\n  author = {Rivoire, O. and Biroli, G. and Martin, O. C. and M{\\'e}zard, M.},\n  year = {2004},\n  journal = {Eur. Phys. J. B},\n  volume = {37},\n  pages = {55--78}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256468,"version":0,"updated":1753730283776},"$loki":1830},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26730,"entry":"@phdthesis{rivoirePhasesVitreusesOptimisation2005,\n  title = {Phases Vitreuses, Optimisation et Grandes D{\\'e}viations},\n  author = {Rivoire, Olivier},\n  year = {2005},\n  school = {Universit{\\'e} Paris-Sud}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256468,"version":0,"updated":1753730283776},"$loki":1831},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25821,"entry":"@article{rizzoChaosGlassySystems2006,\n  title = {Chaos in Glassy Systems from a {{Thouless-Anderson-Palmer}} Perspective},\n  author = {Rizzo, Tommaso and Yoshino, Hajime},\n  year = {2006},\n  month = feb,\n  journal = {Phys. Rev. B},\n  volume = {73},\n  number = {6},\n  pages = {064416},\n  publisher = {{American Physical Society}},\n  doi = {10.1103/PhysRevB.73.064416}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256469,"version":0,"updated":1753730283776},"$loki":1832},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25704,"entry":"@article{rizzoChaosTemperatureMeanField2001,\n  title = {Against {{Chaos}} in {{Temperature}} in {{Mean-Field Spin-Glass Models}}},\n  author = {Rizzo, T.},\n  year = {2001},\n  journal = {J. Phys. A},\n  volume = {34},\n  pages = {5531--5549}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256469,"version":0,"updated":1753730283776},"$loki":1833},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25823,"entry":"@article{rizzoChaosTemperatureSherringtonKirkpatrick2003,\n  title = {Chaos in Temperature in the {{Sherrington-Kirkpatrick}} Model},\n  author = {Rizzo, T. and Crisanti, A.},\n  year = {2003},\n  journal = {Phys. Rev. Lett.},\n  volume = {90},\n  pages = {137201}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256469,"version":0,"updated":1753730283776},"$loki":1834},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26630,"entry":"@article{rizzoComplexityBetheSpin2004,\n  title = {On the Complexity of the {{Bethe}} Spin Glass},\n  author = {Rizzo, T.},\n  year = {2004}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256469,"version":0,"updated":1753730283776},"$loki":1835},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25679,"entry":"@article{robbinsStochasticApproximationMethod1951,\n  title = {A Stochastic Approximation Method},\n  author = {Robbins, H. and Monro, S.},\n  year = {1951},\n  journal = {Ann. Math. Stat.},\n  volume = {22},\n  number = {3},\n  pages = {400}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256470,"version":0,"updated":1753730283776},"$loki":1836},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26260,"entry":"@article{rodriguez-carmonaIsolationCellfreeBacterial2010,\n  title = {Isolation of Cell-Free Bacterial Inclusion Bodies},\n  author = {{Rodr{\\'i}guez-Carmona}, E. and {Cano-Garrido}, O. and {Seras-Franzoso}, J. and Villaverde, A. and {Garc{\\'i}a-Fruit{\\'o}s}, E.},\n  year = {2010},\n  journal = {Microb. Cell. Fact.},\n  volume = {9},\n  number = {1},\n  pages = {71}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256470,"version":0,"updated":1753730283776},"$loki":1837},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26003,"entry":"@article{roosEntropicForcesBrownian2014,\n  title = {Entropic Forces in {{Brownian}} Motion},\n  author = {Roos, N.},\n  year = {2014},\n  journal = {Am. J. Phys.},\n  volume = {82},\n  number = {12},\n  pages = {1161}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256470,"version":0,"updated":1753730283776},"$loki":1838},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26725,"entry":"@article{runnelsPhaseTransitionBethe1967,\n  title = {Phase Transition of a {{Bethe}} Lattice Gas of Hard Molecules},\n  author = {Runnels, L. K.},\n  year = {1967},\n  journal = {Journal of Mathematical Physics},\n  volume = {8},\n  pages = {2081--2087}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256472,"version":0,"updated":1753730283776},"$loki":1839},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25803,"entry":"@article{saffmanBrownianMotionBiological1975,\n  title = {Brownian Motion in Biological Membranes.},\n  author = {Saffman, P G and Delbr{\\\"u}ck, M},\n  year = {1975},\n  month = aug,\n  journal = {Proc. Natl. Acad. Sci. U.S.A.},\n  volume = {72},\n  number = {8},\n  pages = {3111--3113},\n  issn = {0027-8424, 1091-6490},\n  doi = {10.1073/pnas.72.8.3111},\n  urldate = {2024-11-07},\n  abstract = {Brownian motion (diffusion) of particles in membranes occurs in a highly anisotropic environment. For such particles a translational mobility (independent of velocity) can be defined if the viscosity of the liquid embedding the membrane is taken into account. The results of a model calculation are presented. They suggest that for a realistic situation translational diffusion should be about four times faster in relation to rotational diffusion than in the isotropic case.},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/55LRUYAR/Saffman and Delbrück - 1975 - Brownian motion in biological membranes..pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256472,"version":0,"updated":1753730283776},"$loki":1840},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25809,"entry":"@article{saffmanBrownianMotionThin1976,\n  title = {Brownian Motion in Thin Sheets of Viscous Fluid},\n  author = {Saffman, P G},\n  year = {1976},\n  volume = {73},\n  number = {4},\n  pages = {593},\n  file = {/Users/michelecastellana/Zotero/storage/QZLM96ES/Saffman - 1976 - Brownian motion in thin sheets of viscous fluid.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256472,"version":0,"updated":1753730283776},"$loki":1841},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25759,"entry":"@misc{sahuArbitraryLagrangianEulerian2024,\n  title = {Arbitrary {{Lagrangian}}{\\textendash}{{Eulerian}} Finite Element Method for Lipid Membranes},\n  author = {Sahu, Amaresh},\n  year = {2024},\n  urldate = {2025-01-01},\n  abstract = {An arbitrary Lagrangian{\\textendash}Eulerian finite element method and numerical implementation for curved and deforming lipid membranes is presented here. The membrane surface is endowed with a mesh whose in-plane motion need not depend on the in-plane flow of lipids. Instead, in-plane mesh dynamics can be specified arbitrarily. A new class of mesh motions is introduced, where the mesh velocity satisfies the dynamical equations of a user-specified two-dimensional material. A Lagrange multiplier constrains the out-of-plane membrane and mesh velocities to be equal, such that the mesh and material always overlap. An associated numerical inf{\\textendash}sup instability ensues, and is removed by adapting established techniques in the finite element analysis of fluids. In our implementation, the aforementioned Lagrange multiplier is projected onto a discontinuous space of piecewise linear functions. The new mesh motion is compared to established Lagrangian and Eulerian formulations by investigating a preeminent numerical benchmark of biological significance: the pulling of a membrane tether from a flat patch, and its subsequent lateral translation.},\n  howpublished = {https://arxiv.org/abs/2412.07596},\n  keywords = {Condensed Matter - Soft Condensed Matter,Physics - Biological Physics,Physics - Computational Physics},\n  file = {/Users/michelecastellana/Zotero/storage/XM8UWSN7/Sahu - 2024 - Arbitrary Lagrangian--Eulerian finite element method for lipid membranes.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256473,"version":0,"updated":1753730283776},"$loki":1842},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26894,"entry":"@misc{sahuArbitraryLagrangianEulerian2024a,\n  title = {Arbitrary {{Lagrangian--Eulerian}} Finite Element Method for Lipid Membranes},\n  author = {Sahu, Amaresh},\n  year = {2024},\n  month = dec,\n  number = {arXiv:2412.07596},\n  eprint = {2412.07596},\n  primaryclass = {physics},\n  publisher = {{arXiv}},\n  doi = {10.48550/arXiv.2412.07596},\n  urldate = {2025-06-16},\n  abstract = {An arbitrary Lagrangian--Eulerian finite element method and numerical implementation for curved and deforming lipid membranes is presented here. The membrane surface is endowed with a mesh whose in-plane motion need not depend on the in-plane flow of lipids. Instead, in-plane mesh dynamics can be specified arbitrarily. A new class of mesh motions is introduced, where the mesh velocity satisfies the dynamical equations of a user-specified two-dimensional material. A Lagrange multiplier constrains the out-of-plane membrane and mesh velocities to be equal, such that the mesh and material always overlap. An associated numerical inf--sup instability ensues, and is removed by adapting established techniques in the finite element analysis of fluids. In our implementation, the aforementioned Lagrange multiplier is projected onto a discontinuous space of piecewise linear functions. The new mesh motion is compared to established Lagrangian and Eulerian formulations by investigating a preeminent numerical benchmark of biological significance: the pulling of a membrane tether from a flat patch, and its subsequent lateral translation.},\n  archiveprefix = {arxiv},\n  langid = {english},\n  keywords = {Condensed Matter - Soft Condensed Matter,Physics - Biological Physics,Physics - Computational Physics},\n  file = {/Users/michelecastellana/Zotero/storage/PAHGIMRA/Sahu - 2024 - Arbitrary Lagrangian--Eulerian finite element meth.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256474,"version":0,"updated":1753730283776},"$loki":1843},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26891,"entry":"@article{salac2011,\n  title = {A Level Set Projection Model for Fluid{\\textendash}Fluid Interface Dynamics},\n  author = {Salac, David and Lu, Wei},\n  year = {2011},\n  journal = {Journal of Computational Physics},\n  volume = {230},\n  number = {3},\n  pages = {819--843},\n  publisher = {{Elsevier}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256474,"version":0,"updated":1753730283776},"$loki":1844},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26876,"entry":"@article{salbreuxActinCortexMechanics2012,\n  title = {Actin Cortex Mechanics and Cellular Morphogenesis},\n  author = {Salbreux, Guillaume and Charras, Guillaume and Paluch, Ewa},\n  year = {2012},\n  month = oct,\n  journal = {Trends in Cell Biology},\n  volume = {22},\n  number = {10},\n  pages = {536--545},\n  issn = {09628924},\n  doi = {10.1016/j.tcb.2012.07.001},\n  urldate = {2025-06-15},\n  copyright = {https://www.elsevier.com/tdm/userlicense/1.0/},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/CL7MFEQM/Salbreux et al. - 2012 - Actin cortex mechanics and cellular morphogenesis.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256474,"version":0,"updated":1753730283776},"$loki":1845},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26767,"entry":"@article{salbreuxMechanicsActiveSurfaces2017,\n  title = {Mechanics of Active Surfaces},\n  author = {Salbreux, Guillaume and J{\\\"u}licher, Frank},\n  year = {2017},\n  month = sep,\n  journal = {Phys. Rev. E},\n  volume = {96},\n  number = {3},\n  eprint = {1701.09095},\n  primaryclass = {physics},\n  pages = {032404},\n  issn = {2470-0045, 2470-0053},\n  doi = {10.1103/PhysRevE.96.032404},\n  urldate = {2025-04-25},\n  abstract = {We derive a fully covariant theory of the mechanics of active surfaces. This theory provides a framework for the study of active biological or chemical processes at surfaces, such as the cell cortex, the mechanics of epithelial tissues, or reconstituted active systems on surfaces. We introduce forces and torques acting on a surface, and derive the associated force balance conditions. We show that surfaces with in-plane rotational symmetry can have broken up-down, chiral or planar-chiral symmetry. We discuss the rate of entropy production in the surface and write linear constitutive relations that satisfy the Onsager relations. We show that the bending modulus, the spontaneous curvature and the surface tension of a passive surface are renormalised by active terms. Finally, we identify novel active terms which are not found in a passive theory and discuss examples of shape instabilities that are related to active processes in the surface.},\n  archiveprefix = {arxiv},\n  langid = {english},\n  keywords = {Condensed Matter - Soft Condensed Matter,Physics - Biological Physics},\n  file = {/Users/michelecastellana/Zotero/storage/YGLKFA7F/Salbreux and Jülicher - 2017 - Mechanics of active surfaces.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256475,"version":0,"updated":1753730283776},"$loki":1846},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26103,"entry":"@article{salesFragilityFreeEnergyLandscape2002,\n  title = {Fragility of the {{Free-Energy Landscape}} of a {{Directed Polymer}} in {{Random Media}}},\n  author = {Sales, M. and Yoshino, H.},\n  year = {2002},\n  journal = {Phys. Rev. E},\n  volume = {65},\n  pages = {066131}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256476,"version":0,"updated":1753730283776},"$loki":1847},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26104,"entry":"@article{salesFragilityGlassyState2002,\n  title = {Fragility of the Glassy State of a Directed Polymer in Random Media: {{A}} Replica Approach},\n  author = {Sales, M. and Yoshino, H.},\n  year = {2002}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256476,"version":0,"updated":1753730283776},"$loki":1848},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25940,"entry":"@article{sasakiDeviationsPerfectMemory2002,\n  title = {Deviations from {{Perfect Memory}} in {{Spin Glass Temperature Cycling Experiments}}},\n  author = {Sasaki, M. and Dupuis, V. and Bouchaud, J.-P. and Vincent, E.},\n  year = {2002},\n  journal = {Eur. Phys. J. B},\n  volume = {29},\n  pages = {469}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256477,"version":0,"updated":1753730283776},"$loki":1849},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25954,"entry":"@article{sasakiDiscretenessEntropicFluctuations2002,\n  title = {Discreteness and Entropic Fluctuations in {{GREM-like}} Systems},\n  author = {Sasaki, M. and Martin, O. C.},\n  year = {2002},\n  journal = {Phys. Rev. B.},\n  volume = {66},\n  pages = {174411}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256478,"version":0,"updated":1753730283776},"$loki":1850},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26446,"entry":"@article{sasakiMemoryEffectRejuvenation2000,\n  title = {Memory {{Effect}}, {{Rejuvenation}} and {{Chaos Effect}} in the {{Multi-Layer Random Energy Model}}},\n  author = {Sasaki, M. and Nemoto, K.},\n  year = {2000},\n  journal = {J. Phys. Soc. Jpn},\n  volume = {69},\n  pages = {2283}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256479,"version":0,"updated":1753730283776},"$loki":1851},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26037,"entry":"@article{saulExactIntegerAlgorithm1993,\n  title = {Exact Integer Algorithm for the Two-Dimensional {\\textbackslash}pm {{J Ising}} Spin Glass},\n  author = {Saul, L. and Kardar, M.},\n  year = {1993},\n  journal = {Phys. Rev. E},\n  volume = {48},\n  pages = {3221--3224}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256479,"version":0,"updated":1753730283776},"$loki":1852},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25987,"entry":"@article{scanzianiElectrophysiologyAgeLight2009,\n  title = {Electrophysiology in the Age of Light},\n  author = {Scanziani, M. and H{\\\"a}usser, M.},\n  year = {2009},\n  journal = {Nature},\n  volume = {461},\n  number = {7266},\n  pages = {930--939},\n  publisher = {{Nature Publishing Group}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256479,"version":0,"updated":1753730283776},"$loki":1853},{"exportNotes":false,"useJourna