{"name":"Better BibTeX","data":[{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26073,"entry":"@unpublished{a.amraouiFiniteLengthScalingIteratively2004,\n  type = {Submitted},\n  title = {Finite-{{Length Scaling}} for {{Iteratively Decoded LDPC Ensembles}}},\n  author = {{A. Amraoui} and {A. Montanari} and {T. Richardson} and {R. Urbanke}},\n  year = {2004}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255748,"version":0,"updated":1753730283776},"$loki":1011},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26656,"entry":"@article{a.crisantiTAPApproachSpherical1995,\n  title = {On the {{TAP}} Approach to the Spherical {{P-spin SG}} Model},\n  author = {{A. Crisanti} and Sommers, H.-J.},\n  year = {1995},\n  journal = {J. Phys. I (France)},\n  volume = {5},\n  pages = {805}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255761,"version":0,"updated":1753730283776},"$loki":1012},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26317,"entry":"@book{aartsLocalSearchCombinatorial1997,\n  title = {Local {{Search}} in {{Combinatorial Optimization}}},\n  editor = {Aarts, E. H. L. and Lenstra, J. K.},\n  year = {1997},\n  publisher = {{J. Wiley \\& and Sons}},\n  address = {{New York}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255769,"version":0,"updated":1753730283776},"$loki":1013},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25662,"entry":"@article{abou-chacraSelfconsistentTheoryLocalization1973,\n  title = {A Selfconsistent Theory of Localization},\n  author = {{Abou-Chacra}, R. and Thouless, D. J. and Anderson, P. W.},\n  year = {1973},\n  journal = {Journal of Physics C: Solid State Physics},\n  volume = {6},\n  number = {10},\n  pages = {1734},\n  abstract = {A new basis has been found for the theory of localization of electrons in disordered systems. The method is based on a selfconsistent solution of the equation for the self energy in second order perturbation theory, whose solution may be purely real almost everywhere (localized states) or complex everywhere (nonlocalized states). The equations used are exact for a Bethe lattice. The selfconsistency condition gives a nonlinear integral equation in two variables for the probability distribution of the real and imaginary parts of the self energy. A simple approximation for the stability limit of localized states gives Anderson's 'upper limit approximation'. Exact solution of the stability problem in a special case gives results very close to Anderson's best estimate.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255779,"version":0,"updated":1753730283776},"$loki":1014},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26175,"entry":"@book{abramowitzHandbookMathematicalFunctions1972a,\n  title = {Handbook of Mathematical Functions: {{With}} Formulas, Graphs, and Mathematical Tables},\n  editor = {Abramowitz, M. and Stegun, I. A.},\n  year = {1972},\n  publisher = {{National Bureau of Standards}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255781,"version":0,"updated":1753730283776},"$loki":1015},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25715,"entry":"@unpublished{achlioptasAlgorithmicBarriersPhase2008,\n  title = {Algorithmic Barriers from Phase Transitions},\n  author = {Achlioptas, Dimitris and {Coja-Oghlan}, Amin},\n  year = {2008}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255783,"version":0,"updated":1753730283776},"$loki":1016},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25718,"entry":"@article{achlioptasAlmostAllGraphs2003,\n  title = {Almost All Graphs with Average Degree 4 Are 3-{{Colorable}}},\n  author = {Achlioptas, D. and Moore, C.},\n  year = {2003},\n  journal = {J. Comput. Syst. Sci.},\n  volume = {67},\n  pages = {441}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255788,"version":0,"updated":1753730283776},"$loki":1017},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26133,"entry":"@inproceedings{achlioptasGeneratingSatisfiableProblem2000,\n  title = {Generating {{Satisfiable Problem Instances}}},\n  booktitle = {Proceedings of {{AAAI-2000}}, {{Austin}}, {{Texas}}, {{USA}}},\n  author = {Achlioptas, D. and Gomes, C. and Kautz, H. and Selman, B.},\n  year = {2000}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255791,"version":0,"updated":1753730283776},"$loki":1018},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26180,"entry":"@article{achlioptasHidingTruthAssignments2005,\n  title = {Hiding {{Truth Assignments}}: {{Two}} Are {{Better Than One}}},\n  author = {Achlioptas, D. and Jia, H. and Moore, C.},\n  year = {2005},\n  journal = {Journal of Artifical Intelligence Research},\n  volume = {24},\n  pages = {623=-639}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255793,"version":0,"updated":1753730283776},"$loki":1019},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25665,"entry":"@article{achlioptasSharpThresholdKcolorability1999a,\n  title = {A Sharp Threshold for {{K-colorability}}},\n  author = {Achlioptas, Dimitris and Friedgut, Ehud},\n  year = {1999},\n  journal = {Random Struct. Algorithms},\n  volume = {14},\n  number = {1},\n  pages = {63--70},\n  publisher = {{John Wiley \\& Sons, Inc.}},\n  address = {{New York, NY, USA}},\n  issn = {1042-9832},\n  doi = {http://dx.doi.org/10.1002/(SICI)1098-2418(1999010)14:1<63::AID-RSA3>3.0.CO;2-7}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255800,"version":0,"updated":1753730283776},"$loki":1020},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25667,"entry":"@inproceedings{achlioptasSharpThresholdProof2001,\n  title = {A Sharp Threshold in Proof Complexity},\n  booktitle = {{{ACM Symposium}} on {{Theory}} of {{Computing}}},\n  author = {Achlioptas, Dimitris and Beame, Paul and Molloy, Michael S. O.},\n  year = {2001},\n  pages = {337--346}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255807,"version":0,"updated":1753730283776},"$loki":1021},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26651,"entry":"@inproceedings{achlioptasSolutionspaceGeometryRandom2006,\n  title = {On the Solution-Space Geometry of Random Constraint Satisfaction Problems},\n  booktitle = {Proc. of 38th {{STOC}}},\n  author = {Achlioptas, Dimitris and {Ricci-Tersenghi}, Federico},\n  year = {2006},\n  pages = {130--139},\n  publisher = {{ACM}},\n  address = {{New York, NY, USA}},\n  doi = {http://doi.acm.org/10.1145/1132516.1132537}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255811,"version":0,"updated":1753730283776},"$loki":1022},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25632,"entry":"@article{ackleyLearningAlgorithmBoltzmann1987,\n  title = {A Learning Algorithm for {{Boltzmann}} Machines},\n  author = {Ackley, David H. and Hinton, Geoffrey E. and Sejnowski, Terrence J.},\n  year = {1987},\n  pages = {522--533},\n  publisher = {{Morgan Kaufmann Publishers Inc.}},\n  address = {{San Francisco, CA, USA}},\n  isbn = {0-934613-33-8}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255813,"version":0,"updated":1753730283776},"$loki":1023},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25790,"entry":"@article{adalsteinssonBiochemicalNetworkStochastic2004,\n  title = {Biochemical {{Network Stochastic Simulator}} ({{BioNetS}}): {{Software}} for Stochastic Modeling of Biochemical Networks},\n  author = {Adalsteinsson, David and McMillen, David and Elston, Timothy C.},\n  year = {2004},\n  month = mar,\n  journal = {BMC Bioinformatics},\n  volume = {5},\n  number = {1},\n  pages = {24},\n  issn = {1471-2105},\n  doi = {10.1186/1471-2105-5-24},\n  abstract = {Intrinsic fluctuations due to the stochastic nature of biochemical reactions can have large effects on the response of biochemical networks. This is particularly true for pathways that involve transcriptional regulation, where generally there are two copies of each gene and the number of messenger RNA (mRNA) molecules can be small. Therefore, there is a need for computational tools for developing and investigating stochastic models of biochemical networks.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255815,"version":0,"updated":1753730283776},"$loki":1024},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26657,"entry":"@article{adamTemperatureDependenceCooperative1965,\n  title = {On the Temperature Dependence of Cooperative Relaxation Properties in Glass-Forming Liquids},\n  author = {Adam, G. and Gibbs, J.H.},\n  year = {1965},\n  journal = {The journal of chemical physics},\n  volume = {43},\n  number = {1},\n  pages = {139}\n}\n","metadata":