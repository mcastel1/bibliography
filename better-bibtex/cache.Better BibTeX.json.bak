i":1569},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26164,"entry":"@article{liersGroundStateBethelattice,\n  title = {Ground State of the {{Bethe-lattice}} Spin Glass and Running Time of an Exact Optimization Algorithm},\n  author = {Liers, F. and Palassini, M. and Hartmann, A. K. and Juenger, M.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256344,"version":0,"updated":1753730283776},"$loki":1570},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26240,"entry":"@book{lifshitzIntroductionTheoryDisordered1988,\n  title = {Introduction to the Theory of Disordered Systems},\n  author = {Lifshitz, M. and Gredeskul, S. A. and {L. A. Pastur}},\n  year = {1988},\n  publisher = {{Wiley, New York}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256344,"version":0,"updated":1753730283776},"$loki":1571},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25869,"entry":"@article{linComputerSolutionsTraveling1965,\n  title = {Computer {{Solutions}} of the {{Traveling Salesman Problem}}},\n  author = {Lin, S.},\n  year = {1965},\n  journal = {Bell System Technical Journal},\n  volume = {44},\n  pages = {2245--2269}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256345,"version":0,"updated":1753730283776},"$loki":1572},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25724,"entry":"@article{linEffectiveHeuristicAlgorithm1973,\n  title = {An {{Effective Heuristic Algorithm}} for the {{Traveling Salesman Problem}}},\n  author = {Lin, S. and Kernighan, B.},\n  year = {1973},\n  journal = {Operations Research},\n  volume = {21},\n  pages = {498--516}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256345,"version":0,"updated":1753730283776},"$loki":1573},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26112,"entry":"@article{lingFreeenergySurfaceSpinglasses1983,\n  title = {Free-Energy Surface of Spin-Glasses: {{Thouless-Anderson-Palmer}} and {{Bethe-Peierls-Weiss}} Models},\n  author = {Ling, David D. and Bowman, David R. and {K. Levin}},\n  year = {1983},\n  journal = {Phys, Rev. B},\n  volume = {28},\n  pages = {262--269}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256345,"version":0,"updated":1753730283776},"$loki":1574},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26554,"entry":"@article{liNonequilibriumPhaseSeparation2020,\n  title = {Non-Equilibrium Phase Separation with Reactions: {{A}} Canonical Model and Its Behaviour},\n  author = {Li, Y. I. and Cates, M. E.},\n  year = {2020},\n  journal = {J. Stat. Mech. - Theory E.},\n  volume = {2020},\n  number = {5},\n  pages = {053206},\n  abstract = {Materials undergoing both phase separation and chemical reactions (defined here as all processes that change particle type or number) form an important class of non-equilibrium systems. Examples range from suspensions of self-propelled bacteria with birth{\\textendash}death dynamics, to bio-molecular condensates, or `membraneless organelles', within cells. In contrast to their passive counterparts, such systems have conserved and non-conserved dynamics that do not, in general, derive from a shared free energy. This mismatch breaks time-reversal symmetry and leads to new types of dynamical competition that are absent in or near equilibrium. We construct a canonical scalar field theory to describe such systems, with conserved and non-conserved dynamics obeying model B and model A, respectively (in the Hohenberg{\\textendash}Halperin classification), chosen such that the two free energies involved are incompatible. The resulting minimal model is shown to capture the various phenomenologies reported previously for more complicated models with the same physical ingredients, including microphase separation, limit cycles and droplet splitting. We find a low-dimensional subspace of parameters for which time-reversal symmetry is accidentally recovered, and show that here the dynamics of the order parameter field (but not its conserved current) is exactly the same as an equilibrium system in which microphase separation is caused by long-range attractive interactions.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256346,"version":0,"updated":1753730283776},"$loki":1575},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25654,"entry":"@article{linussonProofParisiConjecture2004,\n  title = {A Proof of {{Parisi}}'s Conjecture on the Random Assignment Problem},\n  author = {Linusson, S. and Wastlund, J.},\n  year = {2004},\n  journal = {Probability Theory and Related Fields},\n  volume = {128},\n  pages = {419--440}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256346,"version":0,"updated":1753730283776},"$loki":1576},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26116,"entry":"@article{liOneSolution3satisfiability2009,\n  title = {From One Solution of a 3-{{Satisfiability}} Formula to a Solution Cluster: {{Frozen}} Variables and Entropy},\n  author = {Li, Kang and Ma, Hui and Zhou, Haijun},\n  year = {2009},\n  journal = {Phys. Rev. E},\n  volume = {79},\n  pages = {031102}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256347,"version":0,"updated":1753730283776},"$loki":1577},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexU