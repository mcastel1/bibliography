Tka{\\v c}ik, G. and Schneidman, E. and Berry II, M. J. and Bialek, W.},\n  year = {2006}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256516,"version":0,"updated":1753730283776},"$loki":1927},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26668,"entry":"@article{tkacikOptimalPopulationCoding2010,\n  title = {Optimal Population Coding by Noisy Spiking Neurons},\n  author = {Tka{\\v c}ik, G. and Prentice, J. S. and Balasubramanian, V. and Schneidman, E.},\n  year = {2010},\n  journal = {P. Natl. Acad. Sci. USA},\n  volume = {107},\n  number = {32},\n  pages = {14419--14424},\n  publisher = {{National Acad Sciences}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256517,"version":0,"updated":1753730283776},"$loki":1928},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25839,"entry":"@article{tozziniCoarsegrainedModelsProteins2005,\n  title = {Coarse-Grained Models for Proteins},\n  author = {Tozzini, V.},\n  year = {2005},\n  journal = {Curr. Opin. Struc. Biol.},\n  volume = {15},\n  number = {2},\n  pages = {144},\n  publisher = {{Elsevier}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256517,"version":0,"updated":1753730283776},"$loki":1929},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25889,"entry":"@article{tsuchidaCooperativeReactionsPolyLlysineheme1976,\n  title = {Cooperative Reactions of Poly-{{L-lysine-heme}} Complex with Molecular Oxygen, Carbon Monoxide, or Cyanide Ion},\n  author = {Tsuchida, E. and Hasegawa, E. and Honda, K.},\n  year = {1976},\n  month = apr,\n  journal = {Biochim Biophys Acta},\n  volume = {427},\n  number = {2},\n  pages = {520--529},\n  issn = {0006-3002},\n  doi = {10.1016/0005-2795(76)90194-x},\n  abstract = {The interaction of the alpha-helical poly-L-lysine-heme complex with molecular oxygen, carbon monoxide, or cyanide ion was studied. Binding equilibrium curve and activation parameters for the reactions were determined. Sigmoid responses were observed for the absorption of molecular oxygen or carbon monoxide by the complex and the cooperative parameter was found to be 2.1. This indicated a cooperative interaction between hemes situated on a cylindrical alpha-helix of poly-L-lysine. But those of other polymer-ligand-heme complexes were 1.0. The cooperative reaction mechanism, in which an alpha-helical poly-L-lysine plays an important role, was suggested.},\n  langid = {english},\n  pmid = {5128},\n  keywords = {Binding Sites,Calorimetry,Carbon Monoxide,Circular Dichroism,Cyanides,Heme,Hydrogen-Ion Concentration,Kinetics,Lysine,Oxygen,Partial Pressure,Peptides,Protein Binding,Protein Conformation,Spectrophotometry,Thermodynamics}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256518,"version":0,"updated":1753730283776},"$loki":1930},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25945,"entry":"@article{vaillsDirectEvidenceRigidity2004,\n  title = {Direct Evidence of Rigidity Loss and Self-Organisation in Silicate Glasses},\n  author = {Vaills, Y. and Qu, T. and Micoulaut, M. and Chaimbault, F. and Boolchand, P.},\n  year = {2004}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256518,"version":0,"updated":1753730283776},"$loki":1931},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25695,"entry":"@article{vanenterAbsencePhaseTransitions1985,\n  title = {Absence of Phase Transitions in Certain One-Dimensional Long-Range Random Systems},\n  author = {{van Enter}, A. C. D. and {van Hemmen}, J. L.},\n  year = {1985},\n  journal = {J. Stat. Phys.},\n  volume = {39},\n  number = {1},\n  pages = {1}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256519,"version":0,"updated":1753730283776},"$loki":1932},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26600,"entry":"@article{vankampenSymmetricalCanonicalReduction1937,\n  title = {On a {{Symmetrical Canonical Reduction}} of the {{Problem}} of {{Three Bodies}}},\n  author = {Van Kampen, E. R. and Wintner, A.},\n  year = {1937},\n  journal = {Am. J. Math.},\n  volume = {59},\n  number = {1},\n  pages = {153}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256519,"version":0,"updated":1753730283776},"$loki":1933},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26652,"entry":"@article{vannimenusStatisticalMechanicsOptimization1984,\n  title = {On the {{Statistical Mechanics}} of {{Optimization Problems}} of the {{Travelling Salesman Type}}},\n  author = {Vannimenus, J. and M{\\'e}zard, M.},\n  year = {1984},\n  journal = {J. Physique Lett.},\n  volume = {45},\n  pages = {L1145--L1153}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256519,"version":0,"updated":1753730283776},"$loki":1934},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25865,"entry":"@article{vasquezComputationalComplexityArising2003,\n  title = {Computational Complexity Arising from Degree Correlations in Networks},\n  author = {Vasquez, A. and Weigt, M.},\n  year = {2003},\n  journal = {Phys. Rev. E},\n  volume = {67},\n  pages = {027101}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256519,"version":0,"updated":1753730283776},"$loki":1935},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26888,"entry":"@article{veera2011,\n  title = {Hydrodynamics of Bilayer Membranes with Diffusing Transmembrane Proteins},\n  author = {Veerapaneni, Shravan K. and Gueyffier, David and Biros, George and Zorin, Denis},\n  year = {2011},\n  journal = {Journal of Computational Physics},\n  volume = {230},\n  number = {14},\n  pages = {5610--5634},\n  publisher = {{Elsevier}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256521,"version":0,"updated":1753730283776},"$loki":1936},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26066,"entry":"@article{verduFiftyYearsShannon1998,\n  title = {Fifty {{Years}} of {{Shannon Theory}}},\n  author = {Verd{\\'u}, S.},\n  year = {1998},\n  journal = {IEEE Transactions on Information Theory},\n  volume = {44(6)},\n  pages = {2057--2078}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256521,"version":0,"updated":1753730283776},"$loki":1937},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26159,"entry":"@article{verrierGPCRsRegulateAssembly2011,\n  title = {{{GPCRs}} Regulate the Assembly of a Multienzyme Complex for Purine Biosynthesis},\n  author = {Verrier, F. and An, S. and Ferrie, A. M. and Sun, H. and Kyoung, M. and Deng, H. and Fang, Y. and Benkovic, S. J.},\n  year = {2011},\n  journal = {Nat. Chem. Biol.},\n  volume = {7},\n  number = {12},\n  pages = {909},\n  publisher = {{Nature Publishing Group}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256521,"version":0,"updated":1753730283776},"$loki":1938},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26899,"entry":"@article{verziccoImmersedBoundaryMethods2023,\n  title = {Immersed {{Boundary Methods}}: {{Historical Perspective}} and {{Future Outlook}}},\n  shorttitle = {Immersed {{Boundary Methods}}},\n  author = {Verzicco, Roberto},\n  year = {2023},\n  month = jan,\n  journal = {Annu. Rev. Fluid Mech.},\n  volume = {55},\n  number = {1},\n  pages = {129--155},\n  issn = {0066-4189, 1545-4479},\n  doi = {10.1146/annurev-fluid-120720-022129},\n  urldate = {2025-06-16},\n  abstract = {Immersed boundary methods (IBMs) are versatile and efficient computational techniques to solve flow problems in complex geometric configurations that retain the simplicity and efficiency of Cartesian structured meshes. Although these methods became known in the 1970s and gained credibility only in the new millennium, they had already been conceived and implemented at the beginning of the 1960s, even if the early computers of those times did not allow researchers to exploit their potential. Nowadays IBMs are established numerical schemes employed for the solution of many complex problems in which fluid mechanics may account for only part of the multiphysics dynamics. Despite the indisputable advantages, these methods also have drawbacks, and each problem should be carefully analyzed before deciding which particular IBM implementation is most suitable and whether additional modeling is necessary. High{\\textendash}Reynolds number flows constitute one of the main limitations of IBMs owing to the resolution of thin wall shear layers, which cannot benefit from anisotropic grid refinement at the boundaries. To alleviate this weakness, researchers have developed IBMcompliant wall models and local grid refinement strategies, although in these cases possible pitfalls must also be considered.},\n  copyright = {http://creativecommons.org/licenses/by/4.0/},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/6SPSHYB5/Verzicco - 2023 - Immersed Boundary Methods Historical Perspective .pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256522,"version":0,"updated":1753730283776},"$loki":1939},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26720,"entry":"@article{vianaPhaseDiagramsDilute1985,\n  title = {Phase {{Diagrams}} for {{Dilute Spin-Glasses}}},\n  author = {Viana, L. and Bray, A. J.},\n  year = {1985},\n  journal = {J. Phys. C},\n  volume = {18},\n  pages = {3037--3051}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256522,"version":0,"updated":1753730283776},"$loki":1940},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26578,"entry":"@article{vicsekNovelTypePhase1995,\n  title = {Novel Type of Phase Transition in a System of Self-Driven Particles},\n  author = {Vicsek, T. and Czirok, A. and {Ben-Jacob}, E. and Cohen, I. and Shochet, O.},\n  year = {1995},\n  journal = {Phys. Rev. Lett.},\n  volume = {75},\n  number = {6},\n  pages = {1226}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256522,"version":0,"updated":1753730283776},"$loki":1941},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25710,"entry":"@article{vincentAgingPhenomenaSpinglass2000,\n  title = {Aging Phenomena in Spin-Glass and Ferromagnetic Phases: {{Domain}} Growth and Wall Dynamics},\n  author = {Vincent, E. and Dupuis, V. and Alba, M. and Hammann, J. and Bouchaud, J. P.},\n  year = {2000},\n  journal = {Europhys. Lett.},\n  volume = {50},\n  pages = {674},\n  publisher = {{IOP Publishing}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256523,"version":0,"updated":1753730283776},"$loki":1942},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25857,"entry":"@inproceedings{vincentComplexBehaviourGlassy1997,\n  title = {Complex Behav