//dx.doi.org/10.1006/jagm.1996.0016}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256204,"version":0,"updated":1753730283776},"$loki":1345},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26804,"entry":"@article{fritzEinflussGrosserZaehigkeit1936,\n  title = {{Einflu{\\ss} gro{\\ss}er Z{\\\"a}higkeit bei Str{\\\"o}mung um Zylinder}},\n  author = {Fritz, v., Homann},\n  year = {1936},\n  journal = {Forsch. Ing-Wes.},\n  volume = {7},\n  pages = {1--10},\n  langid = {ngerman},\n  file = {/Users/michelecastellana/Zotero/storage/9326SC9T/Fritz - EinfluB groBer Z ihigkeit bei Str mung um Zylinder.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256206,"version":0,"updated":1753730283776},"$loki":1346},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25732,"entry":"@book{frobergIntroductionGrobnerBases1997,\n  title = {An Introduction to {{Gr{\\\"o}bner}} Bases},\n  author = {Fr{\\\"o}berg, R.},\n  year = {1997},\n  publisher = {{John Wiley \\& Sons}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256207,"version":0,"updated":1753730283776},"$loki":1347},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25750,"entry":"@article{fuApplicationStatisticalMechanics1986,\n  title = {Application of {{Statistical Mechanics}} to {{NP-Complete Problems}} in {{Combinatorial Optimization}}},\n  author = {Fu, Y. and Anderson, P. W.},\n  year = {1986},\n  journal = {J. Phys. A},\n  volume = {19},\n  pages = {1605--1620}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256207,"version":0,"updated":1753730283776},"$loki":1348},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25743,"entry":"@article{fulcherAnalysisRecentData1925,\n  title = {Analysis of Recent Data of the Viscosity of Glasses},\n  author = {Fulcher, {\\relax GS}},\n  year = {1925},\n  journal = {J. Am. Ceram. Soc},\n  volume = {8},\n  pages = {339--355}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256208,"version":0,"updated":1753730283776},"$loki":1349},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25755,"entry":"@article{furtlehnerApproximateInverseIsing2013,\n  title = {Approximate Inverse {{Ising}} Models Close to a {{Bethe}} Reference Point},\n  author = {Furtlehner, C.},\n  year = {2013},\n  journal = {J. Stat. Mech. - Theory E.},\n  volume = {2013},\n  number = {9},\n  pages = {P09020},\n  abstract = {We investigate different ways of generating approximate solutions to the inverse Ising problem (IIP). Our approach consists in taking as a starting point for further perturbation procedures, a Bethe mean-field solution obtained with a maximum spanning tree (MST) of pairwise mutual information, which we refer to as the Bethe reference point . We consider three different ways of following this idea: in the first one, we discuss a greedy procedure by which optimal links to be added starting from the Bethe reference point are selected and calibrated iteratively; the second one is based on the observation that the natural gradient can be computed analytically at the Bethe point; the last one deals with loop corrections to the Bethe point. Assuming no external field and using a dual transform we develop a dual loop joint model based on a well-chosen cycle basis. This leads us to identify a subclass of planar models, which we refer to as dual - loop - free models , having possibly many loops, but characterized by a singly connected dual factor graph, for which the partition function and the linear response can be computed exactly in respectively O ( N ) and O ( N 2 ) operations, thanks to a dual weight propagation (DWP) message passing procedure that we set up. When restricted to this subclass of models, the inverse Ising problem being convex, becomes tractable at any temperature. Numerical experiments show that this can serve to some extent as a good approximation for models with dual loops.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256209,"version":0,"updated":1753730283776},"$loki":1350},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26206,"entry":"@article{fuVivoStructureColi2010,\n  title = {In Vivo Structure of the {{{\\emph{E}}}}{\\emph{. }}{{{\\emph{Coli}}}} {{FtsZ-ring Revealed}} by Photoactivated Localization Microscopy ({{PALM}})},\n  author = {Fu, G. and Huang, T. and Buss, J. and Coltharp, C. and Hensel, Z. and Xiao, J.},\n  year = {2010},\n  journal = {PloS one},\n  volume = {5},\n  number = {9},\n  pages = {e12680}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256210,"version":0,"updated":1753730283776},"$loki":1351},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25905,"entry":"@article{fyodorovCriticalBehaviorNumber2012,\n  title = {Critical {{Behavior}} of the {{Number}} of {{Minima}} of a {{Random Landscape}} at the {{Glass Transition Point}} and the {{Tracy-Widom Distribution}}},\n  author = {Fyodorov, Y. V. and Nadal, C.},\n  year = {2012},\n  journal = {Phys. Rev. Lett.},\n  volume = {109},\n  number = {16},\n  pages = {167203},\n  publisher = {{APS}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256211,"version":0,"updated":1753730283776},"$loki":1352},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26113,"entry":"@article{fyodorovFreezingExtremevalueStatistics2008,\n  title = {Freezing and Extreme-Value Statistics in a Random Energy Model with Logarithmically Correlated Potential},\n  author = {Fyodorov, Y. V. and Bouchaud, J.-P.},\n  year = {2008},\n  journal = {J. Phys. A: Math. Theor.},\n  volume = {41},\n  number = {37},\n  pages = {372001},\n  publisher = {{IOP Publishing}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256211,"version":0,"updated":1753730283776},"$loki":1353},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25840,"entry":"@article{gabayCoexistenceSpinGlassFerromagnetic1981,\n  title = {Coexistence of {{Spin-Glass}} and {{Ferromagnetic Orderings}}},\n  author = {Gabay, Marc and Toulouse, G{\\'e}rard},\n  year = {1981},\n  month = jul,\n  journal = {Phys. Rev. Lett.},\n  volume = {47},\n  number = {3},\n  pages = {201--204},\n  publisher = {{American Physical Society}},\n  doi = {10.1103/PhysRevLett.47.201}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256212,"version":0,"updated":1753730283776},"$loki":1354},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26051,"entry":"@article{gahlmannExploringBacterialCell2014,\n  title = {Exploring Bacterial Cell Biology with Single-Molecule Tracking and Super-Resolution Imaging},\n  author = {Gahlmann, A. and Moerner, W. E.},\n  year = {2014},\n  journal = {Nat. Rev. Microbiol.},\n  volume = {12},\n  number = {1},\n  pages = {9}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256212,"version":0,"updated":1753730283776},"$loki":1355},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26214,"entry":"@book{gallagerInformationTheoryReliable1968,\n  title = {Information Theory and Reliable Communication},\n  author = {Gallager, R. G.},\n  year = {1968},\n  publisher = {{John Wiley and Sons}},\n  address = {{New York}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256213,"version":0,"updated":1753730283776},"$loki":1356},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26332,"entry":"@article{gallagerLowdensityParityCheck1962,\n  title = {Low-Density Parity Check Codes},\n  author = {Gallager, Robert G.},\n  year = {1962},\n  journal = {IEEE Trans. Inform. Theory},\n  volume = {8},\n  pages = {21--28}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256213,"version":0,"updated":1753730283776},"$loki":1357},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26357,"entry":"@article{gamarnikMaximumWeightIndependent2003,\n  title = {Maximum {{Weight Independent Sets}} and {{Matchings}} in {{Sparse Random Graphs}}. {{Exact Results}} Using the {{Local Weak Convergence Method}}},\n  author = {Gamarnik, D. and Nowicki, T. and Swirscsz, G.},\n  year = {2003}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256213,"version":0,"updated":1753730283776},"$loki":1358},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25706,"entry":"@article{garcia-fruitosAggregationBacterialInclusion2005,\n  title = {Aggregation as Bacterial Inclusion Bodies Does Not Imply Inactivation of Enzymes and Fluorescent Proteins},\n  author = {{Garc{\\'i}a-Fruit{\\'o}s}, E. and {Gonz{\\'a}lez-Montalb{\\'a}n}, N. and Morell, M. and Vera, A. and Ferraz, R. M. and Ar{\\'i}s, A. and Ventura, S. and Villaverde, A.},\n  year = {2005},\n  journal = {Microb. Cell. Fact.},\n  volume = {4},\n  number = {1},\n  pages = {27}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256214,"version":0,"updated":1753730283776},"$loki":1359},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26482,"entry":"@article{garcia-perezMolecularCrowdingViscosity1999,\n  title = {Molecular Crowding and Viscosity as Determinants of Translational Diffusion of Metabolites in Subcellular Organelles},\n  author = {{Garc{\\'i}a-P{\\'e}rez}, A. I. and {L{\\'o}pez-Beltr{\\'a}n}, E. A. and Kl{\\\"u}ner, P. and Luque, J. and Ballesteros, P. and Cerd{\\'a}n, S.},\n  year = {1999},\n  journal = {Arch. Biochem. Biophys.},\n  volume = {362},\n  number = {2},\n  pages = {329}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256214,"version":0,"updated":1753730283776},"$loki":1360},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25672,"entry":"@article{gardnerSpinGlassModel1984,\n  title = {A Spin Glass Model on a Hierarchical Lattice},\n  author = {Gardner, E.},\n  year = {1984},\n  journal = {Journal de Physique},\n  volume = {45},\n  number = {11},\n  pages = {1755--1763},\n  publisher = {{Soci{\\'e}t{\\'e} fran{\\c c}aise de physique}},\n  issn = {0302-0738}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256214,"version":0,"updated":1753730283776},"$loki":1361},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25870,"entry":"@book{gareyComputersIntractabilityGuide1979,\n  title = {Computers and Intractability: {{A}} Guide to the Theory of {{NP-completeness}}},\n  author = {Garey, M. R. and Johnson, D. S.},\n  year = {1979},\n  publisher = {{Freeman}},\n  address = {{San Francisco}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256216,"version":0,"updated":1753730283776},"$loki":1362},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26333,"entry":"@article{georgesLowTemperaturePhaseIsing1990,\n  title = {Low-{{Temperature Phase}} of the {{Ising Spin-Glass}} on a {{Hypercubic Lattice}}},\n  author = {Georges, A. and M{\\'e}zard, M. and Yedidia, J. S.},\n  year = {1990},\n  journal = {Phys. Rev. Lett.},\n  volume = {64},\n  pages = {2937--2940}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256216,"version":0,"updated":1753730283776},"$loki":1363},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26146,"entry":"@book{georgiiGibbsMeasuresPhase1988,\n  title = {Gibbs {{Measures}} and {{Phase Transitions}}},\n  author = {Georgii, H.-O.},\n  year = {1988},\n  publisher = {{De Gruyter}},\n  address = {{Berlin}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256217,"version":0,"updated":1753730283776},"$loki":1364},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26531,"entry":"@article{gibbsNatureGlassTransition1958,\n  title = {Nature of the Glass Transition and the Glassy State},\n  author = {Gibbs, J.H. and DiMarzio, E.A.},\n  year = {1958},\n  journal = {The Journal of Chemical Physics},\n  volume = {28},\n  pages = {373}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256217,"version":0,"updated":1753730283776},"$loki":1365},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26008,"entry":"@article{gibsonEnzymaticAssemblyDNA2009,\n  title = {Enzymatic Assembly of {{DNA}} Molecules up to Several Hundred Kilobases},\n  author = {Gibson, D. G. and Young, L. and Chuang, R.-Y. and Venter, C. J. and Hutchison, C. A. and Smith, O. H.},\n  year = {2009},\n  journal = {Nat. Methods},\n  volume = {6},\n  number = {5},\n  pages = {343}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256219,"version":0,"updated":1753730283776},"$loki":1366},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25753,"entry":"@article{gillespieApproximateAcceleratedStochastic2001,\n  title = {Approximate Accelerated Stochastic Simulation of Chemically Reacting Systems},\n  author = {Gillespie, Daniel T.},\n  year = {2001},\n  month = jul,\n  journal = {The Journal of Chemical Physics},\n  volume = {115},\n  number = {4},\n  pages = {1716--1733},\n  issn = {0021-9606},\n  doi = {10.1063/1.1378322},\n  abstract = {The stochastic simulation algorithm (SSA) is an essentially exact procedure for numerically simulating the time evolution of a well-stirred chemically reacting system. Despite recent major improvements in the efficiency of the SSA, its drawback remains the great amount of computer time that is often required to simulate a desired amount of system time. Presented here is the ``{$\\tau$}-leap'' method, an approximate procedure that in some circumstances can produce significant gains in simulation speed with acceptable losses in accuracy. Some primitive strategies for control parameter selection and error mitigation for the {$\\tau$}-leap method are described, and simulation results for two simple model systems are exhibited. With further refinement, the {$\\tau$}-leap method should provide a viable way of segueing from the exact SSA to the approximate chemical Langevin equation, and thence to the conventional deterministic reaction rate equation, as the system size becomes larger.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256219,"version":0,"updated":1753730283776},"$loki":1367},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25621,"entry":"@article{gillespieGeneralMethodNumerically1976,\n  title = {A General Method for Numerically Simulating the Stochastic Time Evolution of Coupled Chemical Reactions},\n  author = {Gillespie, Daniel T},\n  year = {1976},\n  month = dec,\n  journal = {Journal of Computational Physics},\n  volume = {22},\n  number = {4},\n  pages = {403--434},\n  issn = {00219991},\n  doi = {10.1016/0021-9991(76)90041-3},\n  urldate = {2024-10-09},\n  langid = {english}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256220,"version":0,"updated":1753730283776},"$loki":1368},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26504,"entry":"@article{ginsburgMultienzymeSystems1970,\n  title = {Multienzyme Systems},\n  author = {Ginsburg, A. and Stadtman, E. R.},\n  year = {1970},\n  journal = {Annu. Rev. Biochem.},\n  volume = {39},\n  number = {1},\n  pages = {429}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256220,"version":0,"updated":1753730283776},"$loki":1369},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26828,"entry":"@article{godaMultistepTechniqueImplicit1979,\n  title = {A Multistep Technique with Implicit Difference Schemes for Calculating Two- or Three-Dimensional Cavity Flows},\n  author = {Goda, Katuhiko},\n  year = {1979},\n  month = jan,\n  journal = {Journal of Computational Physics},\n  volume = {30},\n  number = {1},\n  pages = {76--95},\n  issn = {00219991},\n  doi = {10.1016/0021-9991(79)90088-3},\n  urldate = {2025-05-16},\n  copyright = {https://www.elsevier.com/tdm/userlicense/1.0/},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/8VI2456V/Goda - 1979 - A multistep technique with implicit difference sch.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256220,"version":0,"updated":1753730