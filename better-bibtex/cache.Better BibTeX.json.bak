hars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255962,"version":0,"updated":1753730283776},"$loki":1098},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26647,"entry":"@article{bennettReductionProblemBodies1904,\n  title = {On the Reduction of the Problem of n Bodies},\n  author = {Bennett, T. L.},\n  year = {1904},\n  journal = {Mess. Math.},\n  volume = {34},\n  number = {8},\n  pages = {113}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255962,"version":0,"updated":1753730283776},"$loki":1099},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25955,"entry":"@article{berardetDisorderAveragingFiniteSize2000,\n  title = {Disorder {{Averaging}} and {{Finite-Size Scaling}}},\n  author = {Berardet, K. and P{\\'a}zm{\\'a}ndi, F. and Batrouni, G. G.},\n  year = {2000},\n  journal = {Phys. Rev. Lett.},\n  volume = {84},\n  pages = {4477}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255963,"version":0,"updated":1753730283776},"$loki":1100},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26687,"entry":"@article{bernardiOrderingTemperaturesCritical1996a,\n  title = {Ordering {{Temperatures}} and {{Critical Exponents}} in {{Ising Spin Glasses}}},\n  author = {Bernardi, L. and Parkash, S. and Campbell, I.},\n  year = {1996},\n  journal = {Phys. Rev. Lett.},\n  volume = {77},\n  pages = {2798--2801}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255964,"version":0,"updated":1753730283776},"$loki":1101},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25947,"entry":"@incollection{bernhardDirectTransferMetabolites1986,\n  title = {Direct {{Transfer}} of {{Metabolites Via Enzyme-Enzyme Complexes}}: {{Evidence}} and {{Physiological Significance}}},\n  booktitle = {The {{Organization}} of {{Cell Metabolism}}},\n  author = {Bernhard, S. A. and Srivastava, D. K.},\n  year = {1986},\n  series = {{{NATO ASI Series}}},\n  volume = {127},\n  pages = {143},\n  publisher = {{Springer}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255969,"version":0,"updated":1753730283776},"$loki":1102},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26154,"entry":"@article{bernsteinGlobalAnalysisEscherichia2004,\n  title = {Global Analysis of {{{\\emph{Escherichia Coli}}}} {{RNA}} Degradosome Function Using {{DNA}} Microarrays},\n  author = {Bernstein, J. A. and Lin, P.-H. and Cohen, S. N. and {Lin-Chao}, S.},\n  year = {2004},\n  journal = {Proc. Natl. Acad. Sci. U.S.A.},\n  volume = {101},\n  number = {9},\n  pages = {2758},\n  abstract = {RNase E, an essential endoribonuclease of Escherichia coli, interacts through its C-terminal region with multiple other proteins to form a complex termed the RNA degradosome. To investigate the degradosome's proposed role as an RNA decay machine, we used DNA microarrays to globally assess alterations in the steady-state abundance and decay of 4,289 E. coli mRNAs at single-gene resolution in bacteria carrying mutations in the degradosome constituents RNase E, polynucleotide phosphorylase, RhlB helicase, and enolase. Our results show that the functions of all four of these proteins are necessary for normal mRNA turnover. We identified specific transcripts and functionally distinguishable transcript classes whose half-life and abundance were affected congruently by multiple degradosome proteins, affected differentially by mutations in degradosome constituents, or not detectably altered by degradosome mutations. Our results, which argue that decay of some E. coli mRNAs in vivo depends on the action of assembled degradosomes, whereas others are acted on by degradosome proteins functioning independently of the complex, imply the existence of structural features or biochemical factors that target specific classes of mRNAs for decay by degradosomes.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255973,"version":0,"updated":1753730283776},"$loki":1103},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26536,"entry":"@inproceedings{berrouShannonLimitErrorcorrecting1993,\n  title = {Near {{Shannon}} Limit Error-Correcting Coding: {{Turbo}} Codes},\n  booktitle = {Proc. {{IEEE International Conference}} on {{Communications}}},\n  author = {Berrou, C. and Glavieux, A. and Thitimajshima, P.},\n  year = {1993},\n  pages = {1064--1070}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255974,"version":0,"updated":1753730283776},"$loki":1104},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25967,"entry":"@article{berthierDynamicUltrametricitySpin2001,\n  title = {Dynamic Ultrametricity in Spin Glasses},\n  author = {Berthier, L. and Barrat, J.-L. and Kurchan, J.},\n  year = {2001},\n  journal = {Phys. Rev. E},\n  volume = {63},\n  pages = {016105}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255974,"version":0,"updated":1753730283776},"$loki":1105},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26140,"entry":"@article{berthierGeometricalAspectsAging2002,\n  title = {Geometrical {{Aspects}} of {{Aging}} and {{Rejuvenation}} in the {{Ising Spin Glass}}: {{A Numerical Study}}},\n  author = {Berthier, L. and Bouchaud, J.-P.},\n  year = {2002},\n  journal = {Phys. Rev. B},\n  volume = {66},\n  pages = {054404}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":f