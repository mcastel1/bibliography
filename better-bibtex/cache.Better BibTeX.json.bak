,\n  issn = {0031-9007},\n  doi = {10.1103/PhysRevLett.59.2486},\n  urldate = {2025-04-22},\n  copyright = {http://link.aps.org/licenses/aps-default-license},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/UN869TQD/Zhong-can and Helfrich - 1987 - Instability and Deformation of a Spherical Vesicle.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256546,"version":0,"updated":1753730283776},"$loki":1989},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25926,"entry":"@unpublished{zhouCriticalityHeterogeneitySolution,\n  title = {Criticality and {{Heterogeneity}} in the {{Solution Space}} of {{Random Constraint Satisfaction Problems}}},\n  author = {Zhou, H.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256546,"version":0,"updated":1753730283776},"$loki":1990},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26320,"entry":"@article{zhouLongRangeFrustrationSpinGlass2005,\n  title = {Long-{{Range Frustration}} in a {{Spin-Glass Model}} of the {{Vertex-Cover Problem}}},\n  author = {Zhou, H.},\n  year = {2005},\n  month = jun,\n  journal = {Phys. Rev. Lett.},\n  volume = {94},\n  number = {21},\n  pages = {217203},\n  doi = {10.1103/PhysRevLett.94.217203}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256546,"version":0,"updated":1753730283776},"$loki":1991},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26356,"entry":"@unpublished{zhouMaximumMatchingRandom2003,\n  title = {Maximum Matching on Random Graphs},\n  author = {Zhou, H. and {Ou-Yang}, Z.},\n  year = {2003}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256547,"version":0,"updated":1753730283776},"$loki":1992},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26756,"entry":"@book{zienkiewiczFiniteElementMethod2013,\n  title = {The Finite Element Method: {{Its}} Basis and Fundamentals},\n  shorttitle = {The Finite Element Method},\n  author = {Zienkiewicz, O. C. and Taylor, R. L. and Zhu, J. Z.},\n  year = {2013},\n  edition = {7th edition},\n  publisher = {{Elsevier, Butterworth-Heinemann}},\n  address = {{Amsterdam}},\n  isbn = {978-1-85617-633-0},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/5PV2GP78/Zienkiewicz et al. - 2013 - The finite element method its basis and fundament.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256547,"version":0,"updated":1753730283776},"$loki":1993},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25741,"entry":"@article{zinn-justinAnalysisIsingModel1979,\n  title = {Analysis of {{Ising}} Model Critical Exponents from High-Temperature Series Expansion},\n  author = {{Zinn-Justin}, J.},\n  year = {1979},\n  journal = {Journal de Physique},\n  volume = {40},\n  number = {10},\n  pages = {969--975},\n  publisher = {{Soci{\\'e}t{\\'e} Fran{\\c c}aise de Physique}},\n  issn = {0302-0738}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256547,"version":0,"updated":1753730283776},"$loki":1994},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26728,"entry":"@book{zinn-justinPhaseTransitionsRenormalization2007,\n  title = {Phase Transitions and Renormalization Group},\n  author = {{Zinn-Justin}, J.},\n  year = {2007},\n  publisher = {{Oxford University Press}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256548,"version":0,"updated":1753730283776},"$loki":1995},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25638,"entry":"@article{zouridisModelProteinTranslation2007,\n  title = {A Model for Protein Translation: Polysome Self-Organization Leads to Maximum Protein Synthesis Rates},\n  author = {Zouridis, H. and Hatzimanikatis, V.},\n  year = {2007},\n  journal = {Biophys. J.},\n  volume = {92},\n  number = {3},\n  pages = {717}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256549,"version":0,"updated":1753730283776},"$loki":1996},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26665,"entry":"@article{zukerOptimalComputerFolding1981,\n  title = {Optimal Computer Folding of Large {{RNA}} Sequences Using Thermodynamics and Auxiliary Information},\n  author = {Zuker, M. and Stiegler, P.},\n  year = {1981},\n  journal = {Nucl. Acid. Res.},\n  volume = {9},\n  pages = {133--148}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256549,"version":0,"updated":1753730283776},"$loki":1997},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26173,"entry":"@article{zwickerGrowthDivisionActive2017,\n  title = {Growth and Division of Active Droplets Provides a Model for Protocells},\n  author = {Zwicker, D. and Seyboldt, R. and Weber, C. A. and Hyman, A. A. and J{\\\"u}licher, F.},\n  year = {2017},\n  journal = {Nat. Phys.},\n  volume = {13},\n  number = {4},\n  pages = {408},\n  abstract = {It has been proposed that during the early steps in the origin of life, small droplets could have formed via the segregation of molecules from complex mixtures by phase separation. These droplets could have provided chemical reaction centres. However, whether these droplets could divide and propagate is unclear. Here we examine the behaviour of droplets in systems that are maintained away from thermodynamic equilibrium by an external supply of energy. In these systems, droplets grow by the addition of droplet material generated by chemical reactions. Surprisingly, we find that chemically driven droplet growth can lead to shape instabilities that trigger the division of droplets into two smaller daughters. Therefore, chemically active droplets can exhibit cycles of growth and division that resemble the proliferation of living cells. Dividing active droplets could serve as a model for prebiotic protocells, where chemical reactions in the droplet play the role of a prebiotic metabolism.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256550,"version":0,"updated":1753730283776},"$loki":1998},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26286,"entry":"@misc{kamenskyLectureNotesMAE,\n  title = {Lecture Notes for {{MAE}} 207: {{Finite}} Element Analysis for Coupled Problems},\n  author = {Kamensky, David},\n  year = {2022},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/EMIEIZME/Kamensky - Lecture notes for MAE 207 Finite element analysis.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534288076,"version":0,"updated":1753730283776},"$loki":2001},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26918,"entry":"@article{bazilevsIsogeometricFluidstructureInteraction2008,\n  title = {Isogeometric Fluid-Structure Interaction: Theory, Algorithms, and Computations},\n  shorttitle = {Isogeometric Fluid-Structure Interaction},\n  author = {Bazilevs, Y. and Calo, V. M. and Hughes, T. J. R. and Zhang, Y.},\n  year = {2008},\n  month = dec,\n  journal = {Comput Mech},\n  volume = {43},\n  number = {1},\n  pages = {3--37},\n  publisher = {{Springer Science and Business Media LLC}},\n  issn = {0178-7675, 1432-0924},\n  doi = {10.1007/s00466-008-0315-x},\n  urldate = {2025-07-27},\n  abstract = {We present a fully-coupled monolithic formulation of the fluid-structure interaction of an incompressible fluid on a moving domain with a nonlinear hyperelastic solid. The arbitrary Lagrangian{\\textendash}Eulerian description is utilized for the fluid subdomain and the Lagrangian description is utilized for the solid subdomain. Particular attention is paid to the derivation of various forms of the conservation equations; the conservation properties of the semi-discrete and fully discretized systems; a unified presentation of the generalized-{$\\alpha$} time integration method for fluid-structure interaction; and the derivation of the tangent matrix, including the calculation of shape derivatives. A NURBS-based isogeometric analysis methodology is used for the spatial discretization and three numerical examples are presented which demonstrate the good behavior of the methodology.},\n  copyright = {http://www.springer.com/tdm},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/I3VVLNMK/Bazilevs et al. - 2008 - Isogeometric fluid-structure interaction theory, .pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1753649992132,"version":0,"updated":1753730283776},"$loki":2018},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26747,"entry":"@article{arroyoRelaxationDynamicsFluid2009i,\n  title = {Relaxation Dynamics of Fluid Membranes},\n  author = {Arroyo, M. and DeSimone, A.},\n  year = {2009},\n  month = mar,\n  journal = {Phys. Rev. E},\n  volume = {79},\n  number = {3},\n  pages = {031915},\n  issn = {1539-3755, 1550-2376},\n  doi = {10.1103/PhysRevE.79.031915},\n  urldate = {2024-09-11},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/3T8DZ8CW/Arroyo and DeSimone - 2009 - Relaxation dynamics of fluid membranes.pdf}\n}\n","metadata":{"DeclarePrefC