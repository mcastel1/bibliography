i":1414},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25908,"entry":"@article{hasenbuschCriticalBehaviorThreedimensional2008,\n  title = {Critical Behavior of Three-Dimensional {{Ising}} Spin Glass Models},\n  author = {Hasenbusch, M. and Pelissetto, A. and Vicari, E.},\n  year = {2008},\n  month = dec,\n  journal = {Phys. Rev. B},\n  volume = {78},\n  number = {21},\n  pages = {214205},\n  publisher = {{American Physical Society}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256242,"version":0,"updated":1753730283776},"$loki":1415},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26486,"entry":"@article{hastingsMonteCarloSampling1970,\n  title = {Monte {{Carlo}} Sampling Methods Using {{Markov}} Chains and Their Applications},\n  author = {Hastings, W. K.},\n  year = {1970},\n  journal = {Biometrika},\n  volume = {57},\n  number = {1},\n  pages = {97--109},\n  publisher = {{Biometrika Trust}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256243,"version":0,"updated":1753730283776},"$loki":1416},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26027,"entry":"@article{hatanoEvidenceDropletPicture,\n  title = {Evidence for the Droplet Picture in the {{3D}} {\\textbackslash}pm {{J}} Spin Glass},\n  author = {Hatano, N. and Gubernatis, J. E.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256243,"version":0,"updated":1753730283776},"$loki":1417},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25815,"entry":"@article{hayesCanGetNo1997,\n  title = {Can't Get No Satisfaction},\n  author = {Hayes, B.},\n  year = {1997},\n  journal = {American scientist},\n  volume = {85},\n  pages = {108--112}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256243,"version":0,"updated":1753730283776},"$loki":1418},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25892,"entry":"@article{hedCorrectExtrapolationOverlap2001,\n  title = {Correct Extrapolation of Overlap Distribution in Spin Glasses},\n  author = {Hed, G. and Hartmann, A. K. and Domany, E.},\n  year = {2001},\n  journal = {Europhys. Lett.},\n  volume = {55},\n  pages = {112}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256244,"version":0,"updated":1753730283776},"$loki":1419},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25984,"entry":"@article{helfrichElasticPropertiesLipid1973,\n  title = {Elastic {{Properties}} of {{Lipid Bilayers}}: {{Theory}} and {{Possible Experiments}}},\n  shorttitle = {Elastic {{Properties}} of {{Lipid Bilayers}}},\n  author = {Helfrich, W},\n  year = {1973},\n  month = dec,\n  journal = {Zeitschrift f{\\\"u}r Naturforschung C},\n  volume = {28},\n  number = {11-12},\n  pages = {693--703},\n  issn = {1865-7125, 0939-5075},\n  doi = {10.1515/znc-1973-11-1209},\n  urldate = {2025-04-21},\n  abstract = {Abstract A theory of the elasticity of lipid bilayers is proposed. Three types of strain, i. e. stretching, tilt and curvature, are distinguished and the associated stresses are identified. It is argued that in the case of vesicles (= closed bilayer films) the only elasticity controlling nonspherical shapes is that of curvature. Euler-Lagrange equations are derived for the shape in magnetic fields and under excess outside pressure. It is shown that magnetic fields can deform spherical vesicles into ellipsoids of revolution. Under excess outside pressure the spherical shape becomes unstable at a certain threshold pressure. Both effects can be influenced by a spontaneous curvature of the bilayer. Some possible experiments to determine the elastic properties are also discussed},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/PMAZZFQ5/Helfrich - 1973 - Elastic Properties of Lipid Bilayers Theory and P.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256246,"version":0,"updated":1753730283776},"$loki":1420},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26084,"entry":"@article{herissonFluctuationdissipationRatioSpin2001,\n  title = {Fluctuation-Dissipation Ratio of a Spin Glass in the Aging Regime},\n  author = {Herisson, D. and Ocio, M.},\n  year = {2001},\n  journal = {Phys. Rev. Lett.},\n  volume = {88},\n  pages = {257202}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256246,"version":0,"updated":1753730283776},"$loki":1421},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25619,"entry":"@inproceedings{hertzFrameworkDescriptionPopulation1998,\n  title = {A {{Framework}} for the Description of Population Based Methods},\n  booktitle = {Proceedings of {{Euro XVI}}},\n  author = {Hertz, A. and Kobler, D.},\n  year = {1998}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256246,"version":0,"updated":1753730283776},"$loki":1422},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26241,"entry":"@book{hertzIntroductionTheoryNeural1991,\n  title = {Introduction to the Theory of {{Neural Computation}}},\n  author = {Hertz, J. and Palmer, A. Krogh R. G.},\n  year = {1991},\n  publisher = {{Addison-Wesley}},\n  address = {{Redwood city, CA}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256246,"version":0,"updated":1753730283776},"$loki":1423},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25830,"entry":"@article{hochbergChiralSelectivityVs2023,\n  title = {Chiral Selectivity vs. {{Noise}} in Spontaneous Mirror Symmetry Breaking},\n  author = {Hochberg, David and Buhse, Thomas and Micheau, Jean-Claude and Rib{\\'o}, Josep M.},\n  year = {2023},\n  journal = {Phys. Chem. Chem. Phys.},\n  volume = {25},\n  number = {46},\n  pages = {31583--31595},\n  publisher = {{The Royal Society of Chemistry}},\n  doi = {10.1039/D3CP03311B},\n  abstract = {Mirror symmetry breaking bifurcations, that occur in nonlinear chemical systems leading to final chiral states with very large enantiomeric excess, can be exploited as an efficient chiral signal selector for even the smallest chiral polarizations. This effect of the chiral polarization requires the system's capacity for overcoming thermal noise, which is manifested as fluctuating reaction rate constants. Therefore, we investigate the chiral selectivity across a range of tiny parity-violating energy differences (PVED) in the presence of inevitable non-equilibrium temperature fluctuations. We use a stochastic differential equation simulation methodology (Ito process) that serves as a valuable tool in open systems for identifying the thresholds at which the chiral force induces chiral selectivity in the presence of non-equilibrium temperature fluctuations. This approach enables us to include and analyze chiral selectivity in the presence of other types of fluctuations, such as perturbations in the rate of fluid flow into and out of the reactor and in the clamped input concentrations. These concepts may be of practical interest (i.e., spontaneous deracemizations) but are also useful for a better understanding of the general principles governing the emergence of biological homochirality.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256