255916,"version":0,"updated":1753730283776},"$loki":1072},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25793,"entry":"@article{bandyopadhyayBivariateUniquenessLogistic2004,\n  title = {Bivariate {{Uniqueness}} in the {{Logistic Recursive Distributional Equation}}},\n  author = {Bandyopadhyay, A.},\n  year = {2004}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255916,"version":0,"updated":1753730283776},"$loki":1073},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25902,"entry":"@inproceedings{bandyopadhyayCountingSamplingNew2006,\n  title = {Counting without Sampling: {{New}} Algorithms for Enumeration Problems Using Statistical Physics},\n  booktitle = {Proc. of the 17th {{ACM-SIAM Symposium}} on {{Discrete Algorithms}}},\n  author = {Bandyopadhyay, Antar and Gamarnik, David},\n  year = {2006},\n  pages = {890--899},\n  publisher = {{ACM Press}},\n  address = {{New York, USA}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255919,"version":0,"updated":1753730283776},"$loki":1074},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25899,"entry":"@article{banosCorrespondenceLongrangeShortrange2012,\n  title = {Correspondence between Long-Range and Short-Range Spin Glasses},\n  author = {Ba{\\~n}os, R. A. and Fernandez, L. A. and {Martin-Mayor}, V. and Young, A. P.},\n  year = {2012},\n  journal = {Physical Review B},\n  volume = {86},\n  number = {13},\n  pages = {134416}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255919,"version":0,"updated":1753730283776},"$loki":1075},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26534,"entry":"@article{banosNatureSpinglassPhase2010,\n  title = {Nature of the Spin-Glass Phase at Experimental Length Scales},\n  author = {Ba{\\~n}os, R. Alvarez and Cruz, A. and Fernandez, L. A. and {Gil-Narvion}, J. M. and {Gordillo-Guerrero}, A. and Guidetti, M. and Maiorano, A. and Mantovani, F. and Marinari, E. and {Martin-Mayor}, V. and {Monforte-Garcia}, J. and Sudupe, A. Mu{\\~n}oz and Navarro, D. and Parisi, G. and {Perez-Gaviro}, S. and {Ruiz-Lorenzo}, J. J. and Schifano, S. F. and Seoane, B. and Tarancon, A. and Tripiccione, R. and Yllanes, D.},\n  year = {2010},\n  journal = {J. Stat. Mech. - Theory E.},\n  volume = {2010},\n  number = {6},\n  pages = {P06026}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255921,"version":0,"updated":1753730283776},"$loki":1076},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26545,"entry":"@article{bansalNitscheMethodNavier2024,\n  title = {Nitsche Method for {{Navier}}{\\textendash}{{Stokes}} Equations with Slip Boundary Conditions: {{Convergence}} Analysis and {{VMS-LES}} Stabilization},\n  shorttitle = {Nitsche Method for {{Navier}}{\\textendash}{{Stokes}} Equations with Slip Boundary Conditions},\n  author = {Bansal, Aparna and Barnafi, Nicol{\\'a}s A. and Pandey, Dwijendra Narain},\n  year = {2024},\n  month = sep,\n  journal = {ESAIM: M2AN},\n  volume = {58},\n  number = {5},\n  pages = {2079--2115},\n  issn = {2822-7840, 2804-7214},\n  doi = {10.1051/m2an/2024070},\n  urldate = {2024-11-18},\n  abstract = {In this paper, we analyze Nitsche's method for the stationary Navier{\\textendash}Stokes equations on Lipschitz domains under minimal regularity assumptions. Our analysis provides a robust formulation for implementing slip ( i.e ., Navier) boundary conditions in arbitrarily complex boundaries. The well-posedness of the discrete problem is established using the Banach Ne{\\v c}as{\\textendash}Babu{\\v s}ka and Banach fixed point theorems under standard small data assumptions. We also provide optimal convergence rates for the approximation error. Furthermore, we propose a quasi-static VMS-LES formulation with Nitsche for the Navier{\\textendash}Stokes equations with slip boundary conditions to address the simulation of incompressible fluids at high Reynolds numbers. We validate our theory through several numerical tests in well-established benchmark problems.},\n  file = {/Users/michelecastellana/Zotero/storage/BAQ75E9P/Bansal et al. - 2024 - Nitsche method for Navier–Stokes equations with slip boundary conditions convergence analysis and V.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255929,"version":0,"updated":1753730283776},"$loki":1077},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26632,"entry":"@article{barahonaComputationalComplexityIsing1982,\n  title = {On the Computational Complexity of {{Ising}} Spin Glass Models},\n  author = {Barahona, F.},\n  editor = {Publishing, I. O. P.},\n  year = {1982},\n  journal = {J. Phys. A - Math. Gen.},\n  volume = {15},\n  number = {10},\n  pages = {3241--3253},\n  publisher = {{Dept. de Matematicas, Univ. de Chile, Santiago, Chile}},\n  issn = {0305-4470}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255930,"version":0,"updated":1753730283776},"$loki":1078},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26841,"entry":"@article{barbicVRealTimeSubspaceIntegration,\n  title = {Real-{{Time Subspace Integration}} for {{St}}.{{Venant-Kirchhoff Deformable Models}}},\n  author = {Barbic{\\textasciicaron}, Jernej and James, Doug},\n  abstract = {In this paper, we present an approach for fast subspace integration of reduced-coordinate nonlinear deformable models that is suitable for interactive applications in computer graphics and haptics. Our approach exploits dimensional model reduction to build reducedcoordinate deformable models for objects with complex geometry. We exploit the fact that model reduction on large deformation models with linear materials (as commonly used in graphics) result in internal force models that are simply cubic polynomials in reduced coordinates. Coefficients of these polynomials can be precomputed, for efficient runtime evaluation. This allows simulation of nonlinear dynamics using fast implicit Newmark subspace integrators, with subspace integration costs independent of geometric complexity. We present two useful approaches for generating low-dimensional subspace bases: modal derivatives and an interactive sketching technique. Mass-scaled principal component analysis (mass-PCA) is suggested for dimensionality reduction. Finally, several examples are given from computer animation to illustrate high performance, including force-feedback haptic rendering of a complicated object undergoing large deformations.},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/VSWLVIDH/Barbicˇ and James - Real-Time Subspace Integration for St.Venant-Kirch.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255936,"version":0,"updated":1753730283776},"$loki":1079},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26601,"entry":"@article{barreAdaptabilityIntermediatePhase2005,\n  title = {On Adaptability and Intermediate Phase in Randomly Connected Networks},\n  author = {Barr{\\'e}, J. and Bishop, A. R. and Lookman, T. and Saxena, A.},\n  year = {2005},\n  journal = {Phys. Rev. Lett.},\n  volume = {94},\n  pages = {208701}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255937,"version":0,"updated":1753730283776},"$loki":1080},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26270,"entry":"@article{barreLargeDeviationTechniques2005,\n  title = {Large Deviation Techniques Applied to Systems with Long-Range Interactions},\n  author = {Barr{\\'e}, Julien and Bouchet, Freddy and Dauxois, Thierry and Ruffo, Stefano},\n  year = {2005},\n  journal = {J. Stat. Phys.},\n  volume = {119},\n  pages = {677}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255939,"version":0,"updated":1753730283776},"$loki":1081},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26179,"entry":"@article{barthelHidingSolutionsRandom2002,\n  title = {Hiding {{Solutions}} in {{Random Satisfiability Problems}}: {{A Statistical Mechanics Approach}}},\n  author = {Barthel, W. and Hartmann, A. K. and Leone, M. and {Ricci-Tersenghi}, F. and Weigt, M. and Zecchina, R.},\n  year = {2002},\n  journal = {Phys. Rev. Lett.},\n  volume = {88},\n  pages = {188701}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255946,"version":0,"updated":1753730283776},"$loki":1082},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26904,"entry":"@article{Bassereau_2018,\n  title = {The 2018 Biomembrane Curvature and Remodeling Roadmap},\n  author = {Bassereau, Patricia and Jin, Rui and Baumgart, Tobias and Deserno, Markus and Dimova, Rumiana and Frolov, Vadim A and Bashkirov, Pavel V and Grubm{\\\"u}ller, Helmut and Jahn, Reinhard and Risselada, H Jelger and Johannes, Ludger and Kozlov, Michael M and Lipowsky, Reinhard and Pucadyil, Thomas J and Zeno, Wade F and Stachowiak, Jeanne C and Stamou, Dimitrios and Breuer, Art{\\`u} and Lauritsen, Line and Simon, Camille and Sykes, C{\\'e}cile and Voth, Gregory A and Weikl, Thomas R},\n  year = {2018},\n  month = jul,\n  journal = {Journal of Physics D: Applied Physics},\n  volume = {51},\n  number = {34},\n  pages = {343001},\n  publisher = {{IOP Publishing}},\n  doi = {10.1088/1361-6463/aacb98},\n  abstract = {The importance of curvature as a structural feature of biological membranes has been recognized for many years and has fascinated scientists from a wide range of different backgrounds. On the one hand, changes in membrane morphology are involved in a plethora of phenomena involving the plasma membrane of eukaryotic cells, including endo- and exocytosis, phagocytosis and filopodia formation. On the other hand, a multitude of intracellular processes at the level of organelles rely on generation, modulation, and maintenance of membrane curvature to maintain the organelle shape and functionality. The contribution of biophysicists and biologists is essential for shedding light on the mechanistic understanding and quantification of these processes. Given the vast complexity of phenomena and mechanisms involved in the coupling between membrane shape and function, it is not always clear in what direction to advance to eventually arrive at an exhaustive understanding of this important research area. The 2018 Biomembrane Curvature and Remodeling Roadmap of Journal of Physics D: Applied Physics addresses this need for clarity and is intended to provide guidance both for students who have just entered the field as well as established scientists who would like to improve their orientation within this fascinating area.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255949,"version":0,"updated":1753730283776},"$loki":1083},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25891,"entry":"@article{bauerCorePercolationRandom2001,\n  title = {Core Percolation in Random Graphs: {{A}} Critical Phenomena Analysis},\n  author = {Bauer, M. and Golinelli, O.},\n  year = {2001},\n  journal = {Eur. Phys. J. B},\n  volume = {24},\n  pages = {339--352}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255950,"version":0,"updated":1753730283776},"$loki":1084},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25819,"entry":"@article{baulerChannelingProximityCatalytic2010,\n  title = {Channeling by Proximity: {{The}} Catalytic Advantages of Active Site Colocalization Using {{Brownian}} Dynamics},\n  author = {Bauler, P. and Huber, G. and Leyh, T. and McCammon, J. A.},\n  year = {2010},\n  journal = {J. Phys. Chem. Lett.},\n  volume = {1},\n  number = {9},\n  pages = {1332}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255951,"version":0,"updated":1753730283776},"$loki":1085},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26041,"entry":"@book{baxterExactlySolvedModels1982,\n  title = {Exactly Solved Models in Statistical Mechanics},\n  author = {Baxter, R. J.},\n  year = {1982},\n  publisher = {{Academic Press}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255951,"version":0,"updated":1753730283776},"$loki":1086},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26739,"entry":"@article{baxterPlanarLatticeGases1999,\n  title = {Planar Lattice Gases with Nearest-Neighbour Exclusion},\n  author = {Baxter, R. J.},\n  year = {1999},\n  journal = {Annals of Combin.},\n  volume = {3},\n  pages = {191--203}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255951,"version":0,"updated":1753730283776},"$loki":1087},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26358,"entry":"@inproceedings{bayatiMaximumWeightMatching2005,\n  title = {Maximum {{Weight Matching}} via {{Max-Product Belief Propagation}}},\n  booktitle = {Proc. {{IEEE Int}}. {{Symp}}. {{Information Theory}}},\n  author = {Bayati, M. and Shah, D. and Sharma, M.},\n  year = {2005}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255952,"version":0,"updated":1753730283776},"$loki":1088},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25661,"entry":"@unpublished{bayatiRigorousProofCavity2006,\n  title = {A Rigorous Proof of the Cavity Method for Counting Matchings},\n  author = {Bayati, Mohsen and Nair, Chandra},\n  year = {2006}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255952,"version":0,"updated":1753730283776},"$loki":1089},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25668,"entry":"@inproceedings{bayatiSimplerMaxproductMaximum2006,\n  title = {A Simpler Max-Product Maximum Weight Matching Algorithm and the Auction Algorithm},\n  booktitle = {Proc. {{IEEE Int}}. {{Symp}}. {{Information Theory}}},\n  author = {Bayati, M. and Shah, D. and Sharma, M.},\n  year = {2006}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255953,"version":0,"updated":1753730283776},"$loki":1090},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25729,"entry":"@article{bellettiIndepthViewMicroscopic2009,\n  title = {An In-Depth View of the Microscopic Dynamics of {{Ising}} Spin Glasses at Fixed Temperature},\n  author = {Belletti, F. and Cruz, A. and Fernandez, L. A. and {Gordillo-Guerrero}, A. and Guidetti, M. and Maiorano, A. and Mantovani, F. and Marinari, E. and {Martin-Mayor}, V. and Monforte, J. and others},\n  year = {2009},\n  journal = {Journal of Statistical Physics},\n  volume = {135},\n  number = {5},\n  pages = {1121--1158},\n  publisher = {{Springer}},\n  issn = {0022-4715}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":fa