exURL":"off","DOIandURL":"both","itemID":25975,"entry":"@article{korkmazhanDynamicsTranslationCan2017,\n  title = {Dynamics of Translation Can Determine the Spatial Organization of Membrane-Bound Proteins and Their {{mRNA}}},\n  author = {Korkmazhan, E. and Teimouri, H. and Peterman, N. and Levine, E.},\n  year = {2017},\n  journal = {Proc. Natl. Acad. Sci. U.S.A.},\n  volume = {114},\n  number = {51},\n  pages = {13424}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256321,"version":0,"updated":1753730283776},"$loki":1516},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26663,"entry":"@article{kotliarOnedimensionalSpinglassModel1983,\n  title = {One-Dimensional Spin-Glass Model with Long-Range Random Interactions},\n  author = {Kotliar, G. and Anderson, P. W. and Stein, D. L.},\n  year = {1983},\n  journal = {Phys. Rev. B},\n  volume = {27},\n  number = {1},\n  pages = {602},\n  publisher = {{American Physical Society}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256321,"version":0,"updated":1753730283776},"$loki":1517},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25818,"entry":"@article{kourtisCellspecificMonitoringProtein2009,\n  title = {Cell-Specific Monitoring of Protein Synthesis {\\emph{in Vivo}}},\n  author = {Kourtis, N. and Tavernarakis, N.},\n  year = {2009},\n  journal = {PLoS One},\n  volume = {4},\n  number = {2},\n  pages = {e4547}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256325,"version":0,"updated":1753730283776},"$loki":1518},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26808,"entry":"@article{kovaznayHotwireInvestigationWake1949,\n  title = {Hot-Wire Investigation of the Wake behind Cylinders at Low {{Reynolds}} Numbers},\n  author = {Kovazn{\\'a}y, L. S. G.},\n  year = {1949},\n  month = aug,\n  journal = {Proc. R. Soc. Lond. A},\n  volume = {198},\n  number = {1053},\n  pages = {174--190},\n  issn = {0080-4630, 2053-9169},\n  doi = {10.1098/rspa.1949.0093},\n  urldate = {2025-05-12},\n  abstract = {The hot-wire technique has been used to measure the regular vortex street pattern behind a cylinder at low Reynolds number. Measurements of mean velocity distribution were made both below and above the critical Reynolds number at which the periodic motion appears. Amplitude and phase measurements gave sufficient information for computation of the instantaneous flow pattern of the vortex system. The important points resulting from the investigation are that (i) the critical Reynolds number at which vortices are shed is 40, (ii) in the range of Reynolds numbers investigated the vortices are not shed directly from the cylinder but appear some distance downstream as an instability of the laminar wake.},\n  copyright = {https://royalsociety.org/journals/ethics-policies/data-sharing-mining/},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/BSIX9Y4K/1949 - Hot-wire investigation of the wake behind cylinder.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256326,"version":0,"updated":1753730283776},"$loki":1519},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26738,"entry":"@article{kozuchPigKidneyEpithelial1975,\n  title = {Pig Kidney Epithelial ({{PS}}) Cells: {{A}} Perfect Tool for the Study of Flaviviruses and Some Other Arboviruses},\n  shorttitle = {Pig Kidney Epithelial ({{PS}}) Cells},\n  author = {Kozuch, O. and Mayer, V.},\n  year = {1975},\n  month = nov,\n  journal = {Acta Virol},\n  volume = {19},\n  number = {6},\n  pages = {498},\n  issn = {0001-723X},\n  langid = {english},\n  pmid = {1999},\n  keywords = {Animals,Arbovi