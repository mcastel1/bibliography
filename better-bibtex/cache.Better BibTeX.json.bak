 Fruchter, L. and Campbell, I. A.},\n  year = {2002},\n  journal = {Phys. Rev. Lett.},\n  volume = {88},\n  pages = {207206}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256443,"version":0,"updated":1753730283776},"$loki":1782},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26684,"entry":"@article{petitOrderingSpinGlass1999,\n  title = {Ordering in a Spin Glass under Applied Magnetic Field},\n  author = {Petit, D. and Fruchter, L. and Campbell, I. A.},\n  year = {1999},\n  journal = {Phys. Rev. Lett.},\n  volume = {83},\n  number = {24}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256444,"version":0,"updated":1753730283776},"$loki":1783},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25707,"entry":"@article{piccoAgingEffectsDynamic2001,\n  title = {Aging Effects and Dynamic Scaling in the 3d {{Edwards-Anderson}} Spin Glasses: {{A}} Comparison with Experiments},\n  author = {Picco, M. and {Ricci-Tersenghi}, F. and Ritort, F.},\n  year = {2001},\n  journal = {Eur. Phys. J. B},\n  volume = {21},\n  pages = {211}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256444,"version":0,"updated":1753730283776},"$loki":1784},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25827,"entry":"@article{piccoChaoticMemoryCooling2001,\n  title = {Chaotic, Memory, and Cooling Rate Effects in Spin Glasses: {{Evaluation}} of the {{Edwards-Anderson}} Model},\n  author = {Picco, M. and {Ricci-Tersenghi}, F. and Ritort, F.},\n  year = {2001},\n  journal = {Phys. Rev. B},\n  volume = {63},\n  pages = {174412}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256445,"version":0,"updated":1753730283776