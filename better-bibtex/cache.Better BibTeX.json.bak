":1753730283776},"$loki":1770},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26694,"entry":"@article{parisiPadicNumbersReplica2000,\n  title = {P-Adic Numbers and Replica Symmetry Breaking},\n  author = {Parisi, G. and Sourlas, N.},\n  year = {2000},\n  journal = {Eur. Phys. J. B},\n  volume = {14},\n  number = {3},\n  pages = {535},\n  publisher = {{Springer}},\n  issn = {1434-6028}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256436,"version":0,"updated":1753730283776},"$loki":1771},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26717,"entry":"@article{parisiPhaseDiagramLarge2009,\n  title = {Phase Diagram and Large Deviations in the Free Energy of Mean-Field Spin Glasses},\n  author = {Parisi, G. and Rizzo, T.},\n  year = {2009},\n  journal = {Phys. Rev. B},\n  volume = {79},\n  pages = {134205}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256436,"version":0,"updated":1753730283776},"$loki":1772},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25663,"entry":"@article{parisiSequenceApproximatedSolutions1980,\n  title = {A Sequence of Approximated Solutions to the {{SK}} Model for Spin Glasses},\n  author = {Parisi, G.},\n  editor = {Publishing, I. O. P.},\n  year = {1980},\n  journal = {J. Phys. A - Math. Gen.},\n  volume = {13},\n  number = {4},\n  pages = {L115--L121},\n  publisher = {{Istituto Nazionale de Fisica Nucleare, Lab. Nazionali di Frascati, Roma, Italy}},\n  issn = {0305-4470}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256436,"version":0,"updated":1753730283776},"$loki":1773},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26654,"entry":"@unpublished{parisiSurveypropagationEquationsRandom2002,\n  title = {On the Survey-Propagation Equations for the Random {{K-satisfiability}} Problem},\n  author = {Parisi, G.},\n  year = {2002}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256437,"version":0,"updated":1753730283776},"$loki":1774},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26676,"entry":"@article{parkOptogeneticProteinClustering2017,\n  title = {Optogenetic Protein Clustering through Fluorescent Protein Tagging and Extension of {{CRY2}}},\n  author = {Park, H. and Kim, N. Y. and Lee, S. and Kim, N. and Kim, J. and Heo, W. D.},\n  year = {2017},\n  journal = {Nat. Commun.},\n  volume = {8},\n  number = {1},\n  pages = {30},\n  abstract = {Protein homo-oligomerization is an important molecular mechanism in many biological processes. Therefore, the ability to control protein homo-oligomerization allows the manipulation and interrogation of numerous cellular events. To achieve this, cryptochrome 2 (CRY2) from Arabidopsis thaliana has been recently utilized for blue light-dependent spatiotemporal control of protein homo-oligomerization. However, limited knowledge on molecular characteristics of CRY2 obscures its widespread applications. Here, we identify important determinants for efficient cryptochrome 2 clustering and introduce a new CRY2 module, named ''CRY2clust'', to induce rapid and efficient homo-oligomerization of target proteins by employing diverse fluorescent proteins and an extremely short peptide. Furthermore, we demonstrate advancement and versatility of CRY2clust by comparing against previously reported optogenetic tools. Our work not only expands the optogenetic clustering toolbox but also provides a guideline for designing CRY2-based new optogenetic modules.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256437,"version":0,"updated":1753730283776},"$loki":1775},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26802,"entry":"@article{patelKarmanVortexStreet1978,\n  title = {Karman {{Vortex Street}} behind a {{Circular Cylinder}} by the {{Series Truncation Method}}},\n  author = {Patel, V. A.},\n  year = {1978},\n  journal = {J. Comp. Phys.},\n  volume = {28},\n  pages = {14--42},\n  file = {/Users/michelecastellana/Zotero/storage/XUHQZQA6/1-s2.0-002199917890044X-main.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256437,"version":0,"updated":1753730283776},"$loki":1776},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26484,"entry":"@article{pawleyMonteCarloRenormalizationgroup1984,\n  title = {Monte {{Carlo}} Renormalization-Group Calculations of Critical Behavior in the Simple-Cubic {{Ising}} Model},\n  author = {Pawley, G. S. and Swendsen, R. H. and Wallace, D. J. and Wilson, K. G.},\n  year = {1984},\n  month = apr,\n  journal = {Phys. Rev. B},\n  volume = {29},\n  number = {7},\n  pages = {4030--4040},\n  publisher = {{American Physical Society}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256439,"version":0,"updated":1753730283776},"$loki":1777},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26706,"entry":"@misc{PDFModellingFluid2024,\n  title = {({{PDF}}) {{Modelling}} Fluid Deformable Surfaces with an Emphasis on Biological Interfaces},\n  year = {2024},\n  month = sep,\n  urldate = {2024-09-03},\n  file = {/Users/michelecastellana/Zotero/storage/NMAATX4K/2024 - (PDF) Modelling fluid deformable surfaces with an emphasis on biological interfaces.pdf;/Users/michelecastellana/Zotero/storage/38DIXC8Y/333696460_Modelling_fluid_deformable_surfaces_with_an_emphasis_on_biological_interfaces.html}\n}\n","metadata":{"Declar