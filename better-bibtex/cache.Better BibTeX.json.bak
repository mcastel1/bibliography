J. and Feng, S.},\n  year = {1987},\n  journal = {Phys. Rev. B},\n  volume = {36},\n  pages = {8456}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256018,"version":0,"updated":1753730283776},"$loki":1154},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26479,"entry":"@incollection{bremerModulationChemicalComposition1996,\n  title = {Modulation of Chemical Composition and Other Parameters of the Cell by Growth Rate},\n  booktitle = {{\\emph{Escherichia Coli}} and {{{\\emph{Salmonella}}}}: {{Cellular}} and Molecular Biology},\n  author = {Bremer, H. and Dennis, P. P.},\n  editor = {Neidhardt, F. C.},\n  year = {1996},\n  edition = {2},\n  publisher = {{American society of microbiology}},\n  address = {{Washington, DC}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256020,"version":0,"updated":1753730283776},"$loki":1155},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25680,"entry":"@article{briegerStochasticCellularAutomation1991,\n  title = {A Stochastic Cellular Automation Simulation of the Non-Linear Diffusion Equation},\n  author = {Brieger, L. and Bonomi, E.},\n  year = {1991},\n  journal = {Physica D-Nonlinear Phenomena},\n  volume = {47},\n  number = {1},\n  pages = {159}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256021,"version":0,"updated":1753730283776},"$loki":1156},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26198,"entry":"@article{brochard-wyartHydrodynamicNarrowingTubes2006,\n  title = {Hydrodynamic Narrowing of Tubes Extruded from Cells},\n  author = {{Brochard-Wyart}, F. and Borghi, N. and Cuvelier, D. and Nassoy, P.},\n  year = {2006},\n  month = may,\n  journal = {Proc. Natl. Acad. Sci. U.S.A.},\n  volume = {103},\n  number = {20},\n  pages = {7660--7663},\n  issn = {0027-8424, 1091-6490},\n  doi = {10.1073/pnas.0602012103},\n  urldate = {2025-04-21},\n  abstract = {We discuss the pulling force f required to extrude a lipid tube from a living cell as a function of the extrusion velocity {\\.L} . The main feature is membrane friction on the cytoskeleton. As recently observed for neutrophils, the tether force exhibits a ``shear thinning'' response over a large range of pulling velocities, which was previously interpreted by assuming viscoelastic flows of the sliding membrane. Here, we propose an alternative explanation based on purely Newtonian flow: The diameter of the tether decreases concomitantly with the increase of the membrane tension in the lipid tube. The pulling force is found to vary as {\\.L} 1 3 , which is consistent with reported experimental data for various types of cells.},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/DUDX9KKZ/Brochard-Wyart et al. - 2006 - Hydrodynamic narrowing of tubes extruded from cell.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256023,"version":0,"updated":1753730283776},"$loki":1157},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25997,"entry":"@article{broderixEnergyLandscapeLennardJones2000,\n  title = {Energy Landscape of a {{Lennard-Jones}} Liquid: {{Statistics}} of Stationary Points},\n  author = {Broderix, K. and Bhattacharya, K. K. and Cavagna, A. and Zippelius, A. and Giardina, I.},\n  year = {2000},\n  journal = {Phys. Rev. Lett.},\n  volume = {85},\n  number = {25},\n  pages = {5360}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256024,"version":0,"updated":1753730283776},"$loki":1158},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26885,"entry":"@article{bruckner2019,\n  title = {Interface Turbulence in Active Fluid Monolayers},\n  author = {Br{\\\"u}ckner, David B. and Fink, Alexander and Wenzel, Magdalena and {Fischer-Friedrich}, Elisabeth and Broedersz, Chase P.},\n  year = {2019},\n  journal = {Nature Communications},\n  volume = {10},\n  number = {1},\n  pages = {853},\n  publisher = {{Nature Publishing Group}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256025,"version":0,"updated":1753730283776},"$loki":1159},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26054,"entry":"@article{brunettiExtensiveNumericalSimulations1991,\n  title = {Extensive {{Numerical Simulations}} of {{Weighted Matchings}}: {{Total Length}} and {{Distribution}} of {{Links}} in the {{Optimal Solution}}},\n  author = {Brunetti, R. and Krauth, W. and M{\\'e}zard, M. and Parisi, G.},\n  year = {1991},\n  journal = {Europhys. Lett.},\n  volume = {14},\n  pages = {295--301}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256025,"version":0,"updated":1753730283776},"$loki":1160},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25835,"entry":"@article{buchnerClusteringOptimalArrangement2013,\n  title = {Clustering and {{Optimal Arrangement}} of {{Enzymes}} in {{Reaction-Diffusion Systems}}},\n  author = {Buchner, A. and Tostevin, F. and Gerland, U.},\n  year = {2013},\n  journal = {Phys. Rev. Lett.},\n  volume = {110},\n  number = {20},\n  pages = {208104},\n  publisher = {{APS}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256026,"version":0,"updated":1753730283776},"$loki":1161},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26672,"entry":"@article{buchnerOptimizationCollectiveEnzyme2013,\n  title = {Optimization of Collective Enzyme Activity via Spatial Localization},\n  author = {Buchner, A. and Tostevin, F. and Hinzpeter, F. and Gerland, U.},\n  year = {2013},\n  journal = {J. Chem. Phys.},\n  volume = {139},\n  number = {13},\n  pages = {135101},\n  publisher = {{AIP Publishing LLC}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256029,"version":0,"updated":1753730283776},"$loki":1162},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25618,"entry":"@article{bulatovDichotomyTheoremConstraints2002,\n  title = {A {{Dichotomy Theorem}} for {{Constraints}} on a {{Three-Element Set}}},\n  author = {Bulatov, Andrei A.},\n  year = {2002},\n  journal = {Proc. of FOCS 2002},\n  pages = {649},\n  publisher = {{IEEE Computer Society}},\n  address = {{Los Alamitos, CA, USA}},\n  issn = {0272-5428},\n  doi = {http://doi.ieeecomputersociety.org/10.1109/SFCS.2002.1181990}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256030,"version":0,"updated":1753730283776},"$loki":1163},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26149,"entry":"@article{bundschuhGlassTransitionSecondary,\n  title = {Glass Transition in Secondary Structures Formed by Random {{RNA}} Sequences},\n  author = {Bundschuh, R. and Hwa, T.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256030,"version":0,"updated":1753730283776},"$loki":1164},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26878,"entry":"@article{burdaironCombinedVOFRANSApproach2023,\n  title = {A Combined {{VOF-RANS}} Approach for Studying the Evolution of Incipient Two-Dimensional Wind-Driven Waves over a Viscous Liquid},\n  author = {Burdairon, Florent and Magnaudet, Jacques},\n  year = {2023},\n  month = nov,\n  journal = {European Journal of Mechanics - B/Fluids},\n  volume = {102},\n  pages = {150--167},\n  issn = {09977546},\n  doi = {10.1016/j.euromechflu.2023.08.001},\n  urldate = {2025-06-15},\n  abstract = {Recent laboratory experiments have revealed that important insights into the physical processes involved in the wind-driven generation of surface waves may be obtained by varying the viscosity of the carrying liquid over several orders of magnitude. The present paper reports on the development of a companion approach aimed at studying similar phenomena through numerical simulation, a way expected to remove some of the experimental limitations, especially in the near-interface region, and to allow the relative influence of several physical processes to be assessed by disregarding or inactivating arbitrarily some of them. After reviewing available options, we select and approach based on the combination of a volume of fluid technique to track the evolution of the air{\\textendash}liquid interface, and a two-dimensional Reynolds-averaged version of the Navier{\\textendash}Stokes equations supplemented with a turbulence model to predict the velocity and pressure fields in both fluids. We examine the formal and physical frameworks in which such a time-dependent two-dimensional formulation is meaningful, and close the governing momentum equations with the one-equation Spalart{\\textendash}Allmaras model which directly solves a transport equation for the eddy viscosity. For this purpose, we assume the interface to behave as a rigid wall with respect to turbulent fluctuations in the air, and implement a versatile algorithm to compute the local distance to the interface whatever its shape. We first assess the performance of this model in unseparated and separated single-phase flows over a wavy rigid wall, which are of specific relevance with respect to wind-wave generation. Then, we discuss the initialization protocol used in two-phase simulations, which involves an impulse disturbance with a white noise distribution applied to the interface position. We finally present some examples of interface evolutions obtained at several wind speeds with liquids of various viscosities, and discuss the underlying physics revealed by the associated statistics of interface disturbances, streamline patterns and energy spectra.},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/9D2GF3TG/Burdairon and Magnaudet - 2023 - A combined VOF-RANS approach for studying the evol.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256032,"version":0,"updated":1753730283776},"$loki":1165},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26467,"entry":"@book{burnhamModelSelectionMultimodel2003,\n  title = {Model Selection and Multi-Model Inference : {{A}} Practical Information-Theoretic Approach},\n  author = {Burnham, K. P. and Anderson, D. R.},\n  year = {2003},\n  publisher = {{Springer}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256032,"version":0,"updated":1753730283776},"$loki":1166},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25768,"entry":"@article{burshteinAsymptoticEnumerationMethods2004,\n  title = {Asymptotic {{Enumeration Methods}} for {{Analyzing LDPC Codes}}.},\n  author = {Burshtein, David and Miller, Gadi},\n  year = {2004},\n  journal = {IEEE Transactions on Information Theory},\n  volume = {50},\n  number = {6},\n  pages = {1115--1131}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256033,"version":0,"updated":1753730283776},"$loki":1167},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26204,"entry":"@article{buxbaumRightPlaceRight2014,\n  title = {In the Right Place at the Right Time: {{Visualizing}} and Understanding {{mRNA}} Localization},\n  author = {Buxbaum, A. R. and Haimovich, G. and Singer, R. H.},\n  year = {2014},\n  journal = {Nat. Rev. Mol. Cell Bio.},\n  volume = {16},\n  number = {2},\n  pages = {95}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256033,"version":0,"updated":1753730283776},"$loki":1168},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26313,"entry":"@inproceedings{c.meassonLifeThresholdList2004,\n  type = {Conference},\n  title = {Life above Threshold: {{From}} List Decoding to Area Thereom and {{MSE}}},\n  booktitle = {Proc. {{ITW}}},\n  author = {{C. Measson} and {A. Montanari} and {T. Richardson} and {R. Urbanke}},\n  year = {2004},\n  month = oct,\n  address = {{San Antonio, USA}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256034,"version":0,"updated":1753730283776},"$loki":1169},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25655,"entry":"@article{c.nairProofConjectureDue2003,\n  title = {A Proof of the Conjecture Due to {{Parisi}} for the Finite Random Assignment Problem},\n  author = {C. Nair, B. Prabhakar and Sharma, M.},\n  year = {2003}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256035,"version":0,"updated":1753730283776},"$loki":1170},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25982,"entry":"@article{cabasinoEigenstatesLimitCycles1988,\n  title = {Eigenstates and Limit Cycles in the {\\textbackslash}{{textSK}} Model},\n  author = {Cabasino, S. and Marinari, E. and Paolucci, P. and Parisi, G.},\n  year = {1988},\n  journal = {J. Phys. A},\n  volume = {21},\n  pages = {4201--4210}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256036,"version":0,"updated":1753730283776},"$loki":1171},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25647,"entry":"@article{cacciutoNumericalStudyUltrametricity1997,\n  title = {A {{Numerical Study}} of {{Ultrametricity}} in {{Finite-Dimensional Spin Glasses}}},\n  author = {Cacciuto, A. and Marinari, E. and Parisi, G.},\n  year = {1997},\n  journal = {J. Phys. A},\n  volume = {30},\n  pages = {L263--L269}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256037,"version":0,"updated":1753730283776},"$loki":1172},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26108,"entry":"@article{cahnFreeEnergyNonuniform1958,\n  title = {Free {{Energy}} of a {{Nonuniform System}}. {{I}}. {{Interfacial Free Energy}}},\n  author = {Cahn, J. W. and Hilliard, J. E.},\n  year = {1958},\n  journal = {J. Chem. Phys.},\n  volume = {28},\n  number = {2},\n  pages = {258}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256037,"version":0,"updated":1753730283776},"$loki":1173},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25685,"entry":"@techreport{calegariTaxonomyEvolutionaryAlgorithms1997,\n  title = {A {{Taxonomy}} of {{Evolutionary Algorithms}} in {{Combinatorial Optimisation}}},\n  author = {Calegari, P. and Coray, G. and Hertz, A. and Kobler, D. and Kuonen, P.},\n  year = {1997},\n  institution = {{Swiss Federal Institute of Technology}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256038,"version":0,"updated":1753730283776},"$loki":1174},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25802,"entry":"@article{callanBrokenScaleInvariance1970,\n  title = {Broken Scale Invariance in Scalar Field Theory},\n  author = {Callan, C.G.},\n  year = {1970},\n  journal = {Physical Review D},\n  volume = {2},\n  pages = {1541--1547},\n  issn = {0556-2821}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256040,"version":0,"updated":1753730283776},"$loki":1175},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26458,"entry":"@inproceedings{callanMethodsFieldTheory1976,\n  title = {Methods in {{Field Theory}}},\n  booktitle = {Les {{Houches}} 1975},\n  author = {Callan, C. G.},\n  editor = {Balian, R. and {Zinn-Justin}, J.},\n  year = {1976},\n  address = {{North-Holland, Amsterdam}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256041,"version":0,"updated":1753730283776},"$loki":1176},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25766,"entry":"@article{campanellaAssemblyRegulationGlycolytic2005,\n  title = {Assembly and Regulation of a Glycolytic Enzyme Complex on the Human Erythrocyte Membrane},\n  author = {Campanella, M. E. and Chu, H. and Low, P. S.},\n  year = {2005},\n  journal = {P. Natl. Acad. Sci. USA},\n  volume = {102},\n  number = {7},\n  pages = {2402}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256044,"version":0,"updated":1753730283776},"$loki":1177},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26203,"entry":"@article{campostriniImprovedHightemperatureExpansion1999,\n  title = {Improved High-Temperature Expansion and Critical Equation of State of Three-Dimensional {{Ising-like}} Systems},\n  author = {Campostrini, M. and Pelissetto, A. and Rossi, P. and Vicari, E.},\n  year = {1999},\n  journal = {Phys. Rev. E},\n  volume = {60},\n  number = {4},\n  pages = {3526},\n  publisher = {{American Physical Society}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256045,"version":0,"updated":1753730283776},"$loki":1178},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26339,"entry":"@article{cannellaMagneticOrderingGoldIron1972,\n  title = {Magnetic {{Ordering}} in {{Gold-Iron Alloys}}},\n  author = {Cannella, V. and Mydosh, J. A.},\n  year = {1972},\n  journal = {Phys. Rev. B},\n  volume = {6},\n  number = {11},\n  pages = {4220}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256045,"version":0,"updated":1753730283776},"$loki":1179},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26342,"entry":"@article{cannellaMagneticSusceptibilityAu1971,\n  title = {Magnetic {{Susceptibility}} of {{Au}}{\\textendash}{{Fe Alloys}}},\n  author = {Cannella, V. and Mydosh, J. A. and Budnick, J. I.},\n  year = {1971},\n  journal = {Journal of Applied Physics},\n  volume = {42},\n  number = {4},\n  pages = {1689},\n  abstract = {Over the past years there has been considerable interest in the magnetic properties of the Au(Fe) system. M{\\\"o}ssbauer measurements indicate that a complicated type of long-range ordering occurs below concentrations c of {$\\sim$}12 at.\\% Fe and extends down to c\\&lt;1\\%. Yet no definitive susceptibility study has been carried out over a complete range of temperatures and concentrations in order to characterize the magnetic ordering. We have measured the low-field magnetic susceptibility {$\\chi$}(T) for a series of eight Au{\\textendash}Fe alloys (1{\\textendash}22 at.\\% Fe), and we observe a definite peak in {$\\chi$} at those ordering temperatures determined from the M{\\\"o}ssbauer data. The magnitude of {$\\chi$} greatly increases with c, while the shape of {$\\chi$}(T) in the region of the peak changes from a cusp-like behavior at low c to a behavior for c{$\\greaterequivlnt$}17\\% in which {$\\chi$}(T) gently rises, then sharply falls. These behaviors confirm the existence of a long-range order suggtesive of antiferromagnetism at low c ({$\\leq$}8\\%) with a more typical ferromagnetic ordering at high c. At intermediate c ({$\\approx$}12\\%), {$\\chi$}(T) seems to indicate the presence of a mixed type of long-range order.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256047,"version":0,"updated":1753730283776},"$loki":1180},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26598,"entry":"@article{caponeOffequilibriumConfinedDynamics2006,\n  title = {Off-Equilibrium Confined Dynamics in a Glassy System with Level-Crossing States},\n  author = {Capone, Barbara and Castellani, Tommaso and Giardina, Irene and {Ricci-Tersenghi}, Federico},\n  year = {2006},\n  journal = {Phys. Rev. B (Condensed Matter and Materials Physics)},\n  volume = {74},\n  number = {14},\n  pages = {144301},\n  publisher = {{APS}},\n  doi = {10.1103/PhysRevB.74.144301},\n  keywords = {energy level crossing,spin dynamics,spin glasses,thermodynamics}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256048,"version":0,"updated":1753730283776},"$loki":1181},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25612,"entry":"@article{caracciolo3dIsingSpin1990,\n  title = {3-d {{Ising}} Spin Glasses in a Magnetic Field and Mean Field Theory},\n  author = {Caracciolo, S. and Parisi, G. and Paternallo, S. and Sourlas, N.},\n  year = {1990},\n  journal = {Europhys. Lett.},\n  volume = {11},\n  pages = {783}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256049,"version":0,"updated":1753730283776},"$loki":1182},{"exportNotes":false,"useJournalAbbreviation":true,