Monte Carlo Coarse Graining}} and {{Renormalization}}},\n  author = {Binder, K.},\n  year = {1981},\n  journal = {Phys. Rev. Lett.},\n  volume = {47},\n  number = {9},\n  pages = {693}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255988,"version":0,"updated":1753730283776},"$loki":1120},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26279,"entry":"@article{biroliLatticeGlassModels2002,\n  title = {Lattice {{Glass Models}}},\n  author = {Biroli, G. and M{\\'e}zard, M.},\n  year = {2002},\n  journal = {Phys. Rev. Lett.},\n  volume = {88},\n  pages = {025501}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255988,"version":0,"updated":1753730283776},"$loki":1121},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25689,"entry":"@article{biroliVariationalDescriptionGround2000a,\n  title = {A Variational Description of the Ground State Structure in Random Satisfiability Problems},\n  author = {Biroli, G. and Monasson, R. and Weigt, M.},\n  year = {2000},\n  journal = {Eur. Phys. J. B},\n  volume = {14},\n  pages = {551}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255988,"version":0,"updated":1753730283776},"$loki":1122},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25919,"entry":"@article{bleherCriticalIndicesDyson1975,\n  title = {Critical Indices for {{Dyson}}'s Asymptotically-Hierarchical Models},\n  author = {Bleher, P. M. and Sinai, {\\relax Ya}. G.},\n  year = {1975},\n  journal = {Commun. Math. Phys.},\n  volume = {45},\n  number = {3},\n  pages = {247--278},\n  publisher = {{Springer Berlin / Heidelberg}},\n  issn = {0010-3616},\n  abstract = {It is known that the investigation of the critical point for models of the type of Dyson's hierarchical models is reduced to the solution of some non-linear integral equation. In our previous publication the Gaussian solution was investigated. Here we construct non-Gaussian solutions of the equation and find the expressions for critical indices connected with them. Our procedure permits us to construct meaningful e-expansions.},\n  keywords = {Physics and Astronomy}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255990,"version":0,"updated":1753730283776},"$loki":1123},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25920,"entry":"@article{bleherCriticalIndicesModels1975,\n  title = {Critical Indices for Models with Long Range Forces (Numerical Calculations)},\n  author = {Bleher, P. M.},\n  year = {1975},\n  journal = {Preprint of the Institute of Applied Mathematics of the Academy of Sciences of the USSR}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255991,"version":0,"updated":1753730283776},"$loki":1124},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26246,"entry":"@article{bleherInvestigationCriticalPoint1973,\n  title = {Investigation of the Critical Point in Models of the Type of {{Dyson}}'s Hierarchical Models},\n  author = {Bleher, P. M. and Sinai, J. G.},\n  year = {1973},\n  journal = {Commun. Math. Phys.},\n  volume = {33},\n  number = {1},\n  pages = {23--42},\n  publisher = {{Springer}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255992,"version":0,"updated":1753730283776},"$loki":1125},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26247,"entry":"@article{bleherInvestigationVicinityCritical1973,\n  title = {Investigation of the Vicinity of the Critical Point in Models of the Type of {{Dyson}}'s Hiera