,\n  title = {Mean-Field Theory of the {{Potts}} Glass},\n  author = {Gross, D. J. and Kanter, I. and Sompolinsky, H.},\n  year = {1985},\n  month = jul,\n  journal = {Phys. Rev. Lett.},\n  volume = {55},\n  number = {3},\n  pages = {304--307},\n  publisher = {{American Physical Society}},\n  doi = {10.1103/PhysRevLett.55.304}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256228,"version":0,"updated":1753730283776},"$loki":1385},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26626,"entry":"@article{grundelAsymptoticPropertiesRandom2004,\n  title = {On the Asymptotic Properties of Random Multidimensional Assignment Problems},\n  author = {Grundel, D. A. and Oliveira, C. A. S. and Pardalos, P. M.},\n  year = {2004},\n  journal = {Journal of Optimization Theory and Applications},\n  volume = {122}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256228,"version":0,"updated":1753730283776},"$loki":1386},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25735,"entry":"@article{guermondOverviewProjectionMethods2006,\n  title = {An Overview of Projection Methods for Incompressible Flows},\n  author = {Guermond, J.L. and Minev, P. and Shen, Jie},\n  year = {2006},\n  month = sep,\n  journal = {Computer Methods in Applied Mechanics and Engineering},\n  volume = {195},\n  number = {44-47},\n  pages = {6011--6045},\n  issn = {00457825},\n  doi = {10.1016/j.cma.2005.10.010},\n  urldate = {2024-10-15},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/LD33VW98/Guermond et al. - 2006 - An overview of projection methods for incompressible flows.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256229,"version":0,"updated":1753730283776},"$loki":1387},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25800,"entry":"@article{guerraBrokenReplicaSymmetry2002,\n  title = {Broken {{Replica Symmetry Bounds}} in the {{Mean Field Spin Glass Model}}},\n  author = {Guerra, F.},\n  year = {2002}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256229,"version":0,"updated":1753730283776},"$loki":1388},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26466,"entry":"@article{guetMinimallyInvasiveDetermination2008,\n  title = {Minimally Invasive Determination of {{mRNA}} Concentration in Single Living Bacteria},\n  author = {Guet, C. C. and Bruneaux, L. and Min, T. L. and {Siegal-Gaskins}, D. and Figueroa, I. and Emonet, T. and Cluzel, P.},\n  year = {2008},\n  journal = {Nucleic Acids Res.},\n  volume = {36},\n  number = {12},\n  pages = {e73}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256229,"version":0,"updated":1753730283776},"$loki":1389},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25770,"entry":"@article{guilhasATPDrivenSeparationLiquid2020,\n  title = {{{ATP-Driven Separation}} of {{Liquid Phase Condensates}} in {{Bacteria}}},\n  author = {Guilhas, B. and {et al.}},\n  year = {2020},\n  journal = {Mol. Cell.},\n  volume = {79},\n  number = {2},\n  pages = {293},\n  abstract = {Summary Liquid-liquid phase-separated (LLPS) states are key to compartmentalizing components in the absence of membranes; however, it is unclear whether LLPS condensates are actively and specifically organized in the subcellular space and by which mechanisms. Here, we address this question by focusing on the ParABS DNA segregation system, composed of a centromeric-like sequence (parS), a DNA-binding protein (ParB), and a motor (ParA). We show that parS and ParB associate to form nanometer-sized, round condensates. ParB molecules diffuse rapidly within the nucleoid volume but display confined motions when trapped inside ParB condensates. Single ParB molecules are able to rapidly diffuse between different condensates, and nucleation is strongly favored by parS. Notably, the ParA motor is required to prevent the fusion of ParB condensates. These results describe a novel active mechanism that splits, segregates, and localizes non-canonical LLPS condensates in the subcellular space.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256230,"version":0,"updated":1753730283776},"$loki":1390},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26530,"entry":"@article{guillouMutationalAnalysisCarbamyl1992,\n  title = {Mutational {{Analysis}} of {{Carbamyl Phosphate Synthetase}}. {{Substitution}} of {{Glu84}} 1 {{Leads}} to {{Loss}} of {{Functional Coupling}} between the {{Two Catalytic Domains}} of the {{Synthetase Subunit}}},\n  author = {Guillou, F. and Liao, M. and {Garcia-Espana}, A. and Lusty, C. J.},\n  year = {1992},\n  journal = {Biochemistry-US},\n  volume = {31},\n  number = {6},\n  pages = {1656}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256231,"version":0,"updated":1753730283776},"$loki":1391},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25863,"entry":"@article{gutnickCompoundsWhichServe1969,\n  title = {Compounds Which Serve as the Sole Source of Carbon or Nitrogen for {{{\\emph{Salmonella}}}} Typhimurium {\\textbackslash}rm {{LT-2}}},\n  author = {Gutnick, D. and Calvo, J. M. and Klopotowski, T. and Ames, B. N.},\n  year = {1969},\n  journal = {J. Bacteriol.},\n  volume = {100},\n  number = {1},\n  pages = {215}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256231,"version":