t":false,"packages":[]},"meta":{"revision":0,"created":1751534256170,"version":0,"updated":1753730283776},"$loki":1293},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25711,"entry":"@article{dupuisAgingRejuvanationMemory2002,\n  title = {Aging, Rejuvanation and Memory in Re-Entrant Ferromagnet},\n  author = {Dupuis, V. and Vincent, E. and Alba, M. and Hammann, J.},\n  year = {2002}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256171,"version":0,"updated":1753730283776},"$loki":1294},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25712,"entry":"@article{dupuisAgingRejuvenationMemory2001,\n  title = {Aging, Rejuvenation and Memory Effects in {{Ising}} and {{Heisenberg}} Spin Glasses},\n  author = {Dupuis, V. and Vincent, E. and Hammann, J.-P. Bouchaud J. and Ito, A. and Katori, H. Aruga},\n  year = {2001},\n  journal = {Phys. Rev. B},\n  volume = {64},\n  pages = {174204}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256171,"version":0,"updated":1753730283776},"$loki":1295},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25713,"entry":"@article{dupuisAgingRejuvenationMemory2002,\n  title = {Aging, Rejuvenation and Memory Effects in Re-Entrant Ferromagnets},\n  author = {Dupuis, V. and Vincent, E. and Alba, M. and Hammann, J.},\n  year = {2002},\n  journal = {The European Physical Journal B-Condensed Matter and Complex Systems},\n  volume = {29},\n  number = {1},\n  pages = {19--26},\n  publisher = {{Springer}},\n  issn = {1434-6028}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256173,"version":0,"updated":1753730283776},"$loki":1296},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25976,"entry":"@article{dupuisDynamiqueLenteSystemes2002,\n  title = {Dynamique {{Lente Des Syst{\\`e}mes Magn{\\'e}tiques D{\\'e}sordonn{\\'e}s}}},\n  author = {Dupuis, V.},\n  year = {2002}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256173,"version":0,"updated":1753730283776},"$loki":1297},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26083,"entry":"@article{duxburyFloppyModesFree1999,\n  title = {Floppy {{Modes}} and the {{Free Energy}}: {{Rigidity}} and {{Connectivity Percolation}} on {{Bethe Lattices}}},\n  author = {Duxbury, P. M. and Jacobs, D. J. and Thorpe, M. F. and Moukarzel, C.},\n  year = {1999},\n  journal = {Phys. Rev. E},\n  volume = {59},\n  pages = {2084--2092}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256174,"version":0,"updated":1753730283776},"$loki":1298},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26711,"entry":"@article{duxburyPercolationFrozenOrder2003,\n  title = {Percolation of Frozen Order in Glassy Combinatorial Problems},\n  author = {Duxbury, P. M.},\n  year = {2003}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256174,"version":0,"updated":1753730283776},"$loki":1299},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26045,"entry":"@article{dysonExistencePhaseTransition1969,\n  title = {Existence of a Phase Transition in a One-Dimensional {{Ising}} Ferromagnet},\n  author = {Dyson, F. J.},\n  year = {1969},\n  journal = {Commun. Math. Phys.},\n  volume = {12},\n  number = {2},\n  pages = {91}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256174,"version":0,"updated":1753730283776},"$loki":1300},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26129,"entry":"@article{dysonGeneralTheorySpinwave1956,\n  title = {General Theory of Spin-Wave Interactions},\n  author = {Dyson, F. J.},\n  year = {1956},\n  journal = {Phy. Rev.},\n  volume = {102},\n  number = {5},\n  pages = {1217},\n  abstract = {An ideal model of a ferromagnet is studied; consisting of a lattice of identical spins with cubic symmetry and with isotropic exchange coupling between nearest neighbors. The aim is to obtain a complete description of the thermodynamic properties of the system at low temperatures; far below the Curie point. In this temperature region the natural description of the states of the system is in terms of Bloch spin waves. The nonorthogonality of spin-wave states raises basic difficulties which are examined and overcome. The following new results are obtained: a practical method for calculating thermodynamic quantities in terms of a nonorthogonal set of basic states; a proof that in 3 dimensions there do not exist states (shown by Bethe to exist in a one-dimensional chain of spins) in which two spins are bound together into a stable complex and travel together through the lattice; a calculation of the scattering cross section of two spin waves; giving a mean free path for spin-spin collisions proportional to T -7 / 2 at low temperatures; and an exact formula for the free energy of the system; showing explicitly the effects of spin-wave interactions. Quantitative results based on this theory will be published in a second paper.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256175,"version":0,"updated":1753730283776},"$loki":1301},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26700,"entry":"@article{earlParallelTemperingTheory2005,\n  title = {Parallel Tempering: {{Theory}}, Applications, and New Perspectives},\n  author = {Earl, David J. and Deem, Michael W.},\n  year = {2005},\n  journal = {Physical Chemistry Chemical Physics},\n  volume = {7},\n  number = {23},\n  pages = {3910--3916},\n  publisher = {{The Royal Society of Chemistry}},\n  abstract = {We review the history of the parallel tempering simulation method. From its origins in data analysis, the parallel tempering method has become a standard workhorse of physicochemical simulations. We discuss the theory behind the method and its various generalizations. We mention a selected set of the many applications that have become possible with the introduction of parallel tempering, and we suggest several promising avenues for future research.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256176,"version":0,"updated":1753730283776},"$loki":1302},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25727,"entry":"@incollection{eenExtensibleSATsolver2004,\n  title = {An {{Extensible SAT-solver}}},\n  booktitle = {Theory and {{Applications}} of {{Satisfiability Testing}}},\n  author = {E{\\'e}n, Niklas and Sorensson, Niklas},\n  year = {2004},\n  pages = {502--518},\n  publisher = {{Springer Berlin}},\n  address = {{Heidelberg}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256177,"version":0,"updated":1753730283776},"$loki":1303},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25794,"entry":"@article{efronBootstrapMethodsAnother1979,\n  title = {Bootstrap Methods: {{Another}} Look at the Jackknife},\n  author = {Efron, B.},\n  year = {1979},\n  journal = {Ann. Stati.},\n  volume = {7},\n  number = {1},\n  pages = {1--26},\n  publisher = {{JSTOR}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256177,"version":0,"updated":1753730283776},"$loki":1304},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26007,"entry":"@book{ellisEntropyLargeDeviations1985,\n  title = {Entropy, {{Large Deviations}}, and {{Statistical Mechanics}}},\n  author = {Ellis, R. S.},\n  year = {1985},\n  publisher = {{Springer-Verlag}},\n  address = {{New-York}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256178,"version":0,"updated":1753730283776},"$loki":1305},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25739,"entry":"@article{ellisOverviewTheoryLarge1995,\n  title = {An Overview of the Theory of Large Deviations and Applications to Statistical Physics},\n  author = {Ellis, R. S.},\n  year = {1995},\n  journal = {Scand. Acturial J.},\n  volume = {1},\n  pages = {97--142}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256179,"version":0,"updated":1753730283776},"$loki":1306},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26471,"entry":"@book{embrechtsModellingExtremalEvents1997,\n  title = {Modelling Extremal Events: {{For}} Insurance and Finance},\n  author = {Embrechts, P. and Kl{\\\"u}ppelberg, C. and T, Mikosch},\n  year = {1997},\n  volume = {33},\n  publisher = {{Springer}},\n  address = {{New York}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256182,"version":0,"updated":1753730283776},"$loki":1307},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26081,"entry":"@article{emlenFlockingBehaviourBirds1952,\n  title = {Flocking Behaviour in Birds},\n  author = {Emlen, J. T.},\n  year = {1952},\n  journal = {The Auk.},\n  volume = {69},\n  number = {2},\n  pages = {160}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256183,"version":0,"updated":1753730283776},"$loki":1308},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26606,"entry":"@article{engelLargeDeviationProperties2004,\n  title = {On Large Deviation Properties of {{Erd}}{\\textbackslash}{{Hos-R{\\'e}nyi}} Random Graphs},\n  author = {Engel, A. and Monasson, R. and Hartmann, A. K.},\n  year = {2004},\n  journal = {J. Stat. Phys.},\n  volume = {117},\n  pages = {387}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256184,"version":0,"updated":1753730283776},"$loki":1309},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26637,"entry":"@article{erdhosEvolutionRandomGraphs1960,\n  title = {On the Evolution of Random Graphs},\n  author = {Erd{\\textbackslash}Hos, P. and R{\\'e}nyi, A.},\n  year = {1960},\n  journal = {Publ. Math. Inst. Hungar. Acad. Sci.},\n  volume = {5},\n  pages = {17--61}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256184,"version":0,"updated":1753730283776},"$loki":1310},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26612,"entry":"@article{erdhosRandomGraphs1959,\n  title = {On Random Graphs},\n  author = {Erd{\\textbackslash}Hos, P. and R{\\'e}nyi, A.},\n  year = {1959},\n  journal = {Publ. Math. Debrecen},\n  volume = {6},\n  pages = {290--297}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256184,"version":0,"updated":1753730283776},"$loki":1311},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26869,"entry":"@article{etlingMesoscaleVortexShedding1990,\n  title = {Mesoscale Vortex Shedding from Large Islands: {{A}} Comparison with Laboratory Experiments of Rotating Stratified Flows},\n  shorttitle = {Mesoscale Vortex Shedding from Large Islands},\n  author = {Etling, D.},\n  year = {1990},\n  journal = {Meteorl. Atmos. Phys.},\n  volume = {43},\n  number = {1-4},\n  pages = {145--151},\n  issn = {0177-7971, 1436-5065},\n  doi = {10.1007/BF01028117},\n  urldate = {2025-06-14},\n  abstract = {Mesoscale vortex shedding in the wake of large islands has been analysed with respect to the influence of stratification and background rotation. Comparison with results from laboratory experiments on rotating-stratified flows past isolated obstacles based on Rossby and Froude numbers have shown that for Fr {$<$} 0.4 vortex shedding can be expected for moderate rotation rates. Rossby numbers for cases of atmospheric vortex streets were found to be much larger than in laboratory experiments. Depending on the Froude number different flow pattern in the wake of three-dimensional obstacles have been identified in both, laboratory experiments and atmospheric observations.},\n  copyright = {http://www.springer.com/tdm},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/KJ2H97Y6/Etling - 1990 - Mesoscale vortex shedding from large islands A co.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256185,"version":0,"updated":1753730283776},"$loki":1312},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26558,"entry":"@article{etocNonspecificInteractionsGovern2018,\n  title = {Non-Specific Interactions Govern Cytosolic Diffusion of Nanosized Objects in Mammalian Cells},\n  author = {Etoc, F. and Balloul, E. and Vicario, C. and Normanno, D. and Li{$\\beta$}e, D. and Sittner, A. and Piehler, J. and Dahan, M. and Coppey, M.},\n  year = {2018},\n  journal = {Nat. Mat.},\n  volume = {17},\n  number = {8},\n  pages = {740},\n  abstract = {The diffusivity of macromolecules in the cytoplasm of eukaryotic cells varies over orders of magnitude and dictates the kinetics of cellular processes. However, a general description that associates the Brownian or anomalous nature of intracellular diffusion to the architectural and biochemical properties of the cytoplasm has not been achieved. Here we measure the mobility of individual fluorescent nanoparticles in living mammalian cells to obtain a comprehensive analysis of cytoplasmic diffusion. We identify a correlation between tracer size, its biochemical nature and its mobility. Inert particles with size equal or below 50 nm behave as Brownian particles diffusing in a medium of low viscosity with negligible effects of molecular crowding. Increasing the strength of non-specific interactions of the nanoparticles within the cytoplasm gradually reduces their mobility and leads to subdiffusive behaviour. These experimental observations and the transition from Brownian to subdiffusive motion can be captured in a minimal phenomenological model.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256186,"version":0,"updated":1753730283776},"$loki":1313},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26777,"entry":"@article{evansBiomembraneTemplatesNanoscale1996,\n  title = {Biomembrane {{Templates}} for {{Nanoscale Conduits}} and {{Networks}}},\n  author = {Evans, Evan and Bowman, Howard and Leung, Andrew and Needham, David and Tirrell, David},\n  year = {1996},\n  month = aug,\n  journal = {Science},\n  volume = {273},\n  number = {5277},\n  pages = {933--935},\n  issn = {0036-8075, 1095-9203},\n  doi = {10.1126/science.273.5277.933},\n  urldate = {2025-05-08},\n  abstract = {Long nanotubes of fluid-lipid bilayers can be used to create templates for photochemical polymerization into solid-phase conduits and networks. Each nanotube is pulled from a micropipette-held feeder vesicle by mechanical retraction of the vesicle after molecular bonding to a rigid substrate. The caliber of the tube is controlled precisely in a range from 20 to 200 nanometers merely by setting the suction pressure in the micropipette. Branched conduits can be formed by coalescing separate nanotubes drawn serially from the feeder vesicle surface. Single nanotubes and nanotube junctions can be linked together between bonding sites on a surface to create a functionalized network. After assembly, the templates can be stabilized by photoinitiated radical cross-linking of macromonomers contained in the aqueous solution confined by the lipid bilayer boundary.},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/43YD6CQF/Evans et al. - 1996 - Biomembrane Templates for Nanoscale Conduits and N.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256187,"version":0,"updated":1753730283776},"$loki":1314},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25799,"entry":"@article{evansBroadcastingTreesIsing2000,\n  title = {Broadcasting on Trees and the {{Ising}} Model},\n  author = {Evans, William and Kenyon, Claire and Peres, Yuval and Schulman, Leonard J.},\n  year = {2000},\n  journal = {Ann. Appl. Probab.},\n  volume = {10},\n  pages = {410--433}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256187,"version":0,"updated":1753730283776},"$loki":1315},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25872,"entry":"@article{evansCondensationExtremeValue2008,\n  title = {Condensation and Extreme Value Statistics},\n  author = {Evans, M. R. and Majumdar, S. N.},\n  year = {2008},\n  journal = {J. Stat. Mech. - Theory E.},\n  volume = {2008},\n  number = {05},\n  pages = {P05004},\n  publisher = {{IOP Publishing}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256188,"version":0,"updated":1753730283776},"$loki":1316},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26703,"entry":"@book{evansPartialDifferentialEquations2010,\n  title = {Partial {{Differential Equations}}},\n  author = {Evans, L. C.},\n  year = {2010},\n  series = {Graduate {{Studies}} in {{Mathematics}}},\n  publisher = {{American Mathematical Society}},\n  file = {/Users/michelecastellana/Zotero/storage/UZHXLT9Z/partial-differential-equations-by-evans.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256188,"version":0,"updated":1753730283776},"$loki":1317},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25814,"entry":"@article{f.altarelliCanRareSAT2007,\n  title = {Can Rare {{SAT}} Formulas Be Easily Recognized? {{On}} the Efficiency of Message Passing Algorithms for {{K-SAT}} at Large Clause-to-Variable Ratios},\n  author = {F. Altarelli, R. Monasson and Zamponi, F.},\n  year = {2007},\n  journal = {J. Phys. A: Math. Theor.},\n  volume = {40},\n  pages = {867--886}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256189,"version":0,"updated":1753730283776},"$loki":1318},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26207,"entry":"@incollection{fahnertInclusionBodiesFormation2004,\n  title = {Inclusion {{Bodies}}: {{Formation}} and {{Utilisation}}},\n  booktitle = {Physiological {{Stress Responses}} in {{Bioprocesses}}},\n  author = {Fahnert, B. and Lilie, H. and Neubauer, P.},\n  year = {2004},\n  series = {Adv. {{Biochem}}. {{Eng}}. {{Biot}}.},\n  volume = {89},\n  pages = {93},\n  publisher = {{Springer}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256189,"version":0,"updated":1753730283776},"$loki":1319},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26852,"entry":"@misc{FEATFLOW,\n  title = {{{FEATFLOW}}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256189,"version":0,"updated":1753730283776},"$loki":1320},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25856,"entry":"@inproceedings{feigeCompleteConvergenceMessage2006,\n  title = {Complete Convergence of Message Passing Algorithms for Some Satisfiability Problems},\n  booktitle = {Proc. of {{Random}} 2006, {{LNCS}} 4410},\n  author = {Feige, U. and Mossel, E. and Vilenchik, D.},\n  year = {2006},\n  pages = {339--350}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256190,"version":0,"updated":1753730283776},"$loki":1321},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25693,"entry":"@article{fisherAbsenceManyStates1987,\n  title = {Absence of Many States in Realistic Spin Glasses},\n  author = {Fisher, D. S. and Huse, D. A.},\n  year = {1987},\n  journal = {J. Phys. A - Math. Gen.},\n  volume = {20},\n  pages = {L1005},\n  publisher = {{IOP Publishing}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256190,"version":0,"updated":1753730283776},"$loki":1322},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25948,"entry":"@article{fisherDirectedPathRandom1991,\n  title = {Directed Path in a Random Potential},\n  author = {Fisher, D. S. and Huse, D. A.},\n  year = {1991},\n  journal = {Phys. Rev. B},\n  volume = {43},\n  pages = {10728--10742}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256190,"version":0,"updated":1753730283776},"$loki":1323},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26012,"entry":"@article{fisherEquilibriumBehaviorSpinglass1988,\n  title = {Equilibrium Behavior of the Spin-Glass Ordered Phase},\n  author = {Fisher, D. S. and Huse, D. A.},\n  year = {1988},\n  journal = {Phys. Rev. B},\n  volume = {38},\n  number = {1},\n  pages = {386}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256190,"version":0,"updated":1753730283776},"$loki":1324},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26099,"entry":"@article{fisherFourdimensionalImagingColi2013,\n  title = {Four-Dimensional Imaging of {{{\\emph{E}}}}{\\emph{. }}{{{\\emph{Coli}}}} Nucleoid Organization and Dynamics in Living Cells},\n  author = {Fisher, J. K. and Bourniquel, A. and Witz, G. and Weiner, B. and Prentiss, M. and Kleckner, N.},\n  year = {2013},\n  journal = {Cell},\n  volume = {153},\n  number = {4},\n  pages = {882}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256193,"version":0,"updated":1753730283776},"$loki":1325},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26561,"entry":"@article{fisherNonequilibriumDynamicsSpin1988,\n  title = {Nonequilibrium Dynamics of Spin Glasses},\n  author = {Fisher, D.S. and Huse, D.A.},\n  year = {1988},\n  journal = {Phys. Rev. B},\n  volume = {38},\n  number = {1},\n  pages = {373},\n  publisher = {{APS}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256194,"version":0,"updated":1753730283776},"$loki":1326},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26680,"entry":"@article{fisherOrderedPhaseShortRange1986,\n  title = {Ordered {{Phase}} of {{Short-Range Ising Spin-Glasses}}},\n  author = {Fisher, D. S. and Huse, D. A.},\n  year = {1986},\n  journal = {Phys. Rev. Lett.},\n  volume = {56},\n  number = {15},\n  pages = {1601}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256194,"version":0,"updated":1753730283776},"$loki":1327},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26754,"entry":"@book{frankelGeometryPhysicsIntroduction2011,\n  title = {The {{Geometry}} of {{Physics}}: {{An Introduction}}},\n  shorttitle = {The {{Geometry}} of {{Physics}}},\n  author = {Frankel, Theodore},\n  year = {2011},\n  month = nov,\n  edition = {3},\n  publisher = {{Cambridge University Press}},\n  doi = {10.1017/CBO9781139061377},\n  urldate = {2025-04-21},\n  abstract = {This book provides a working knowledge of those parts of exterior differential forms, differential geometry, algebraic and differential topology, Lie groups, vector bundles and Chern forms that are essential for a deeper understanding of both classical and modern physics and engineering. Included are discussions of analytical and fluid dynamics, electromagnetism (in flat and curved space), thermodynamics, the Dirac operator and spinors, and gauge fields, including Yang{\\textendash}Mills, the Aharonov{\\textendash}Bohm effect, Berry phase and instanton winding numbers, quarks and quark model for mesons. Before discussing abstract notions of differential geometry, geometric intuition is developed through a rather extensive introduction to the study of surfaces in ordinary space. The book is ideal for graduate and advanced undergraduate students of physics, engineering or mathematics as a course text or for self study. This third edition includes an overview of Cartan's exterior differential forms, which previews many of the geometric concepts developed in the text.},\n  isbn = {978-1-107-01673-6 978-1-107-60260-1 978-1-139-06137-7}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256196,"version":0,"updated":1753730283776},"$loki":1328},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26619,"entry":"@article{frankSpontaneousAsymmetricSynthesis1953,\n  title = {On Spontaneous Asymmetric Synthesis},\n  author = {Frank, F.C.},\n  year = {1953},\n  month = jan,\n  journal = {Biochimica et Biophysica Acta},\n  volume = {11},\n  pages = {459--463},\n  issn = {00063002},\n  doi = {10.1016/0006-3002(53)90082-1},\n  urldate = {2024-11-19},\n  langid = {english}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256197,"version":0,"updated":1753730283776},"$loki":1329},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26602,"entry":"@article{franzChaosMeanfieldSpin1995,\n  title = {On Chaos in Mean-Field Spin Glasses},\n  author = {Franz, S. and {Ney-Nifle}, M.},\n  year = {1995},\n  journal = {J. Phys. A},\n  volume = {28},\n  pages = {2499}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256197,"version":0,"updated":1753730283776},"$loki":1330},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26597,"entry":"@article{franzEquilibriumGlassyDynamics1994,\n  title = {Off Equilibrium Glassy Dynamics : {{A}} Simple Case},\n  author = {Franz, S. and M{\\'e}zard, M.},\n  year = {1994},\n  journal = {Europhys. Lett.},\n  volume = {26},\n  pages = {209}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256198,"version":0,"updated":1753730283776},"$loki":1331},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26228,"entry":"@article{franzInterfacesLowerCritical1994,\n  title = {Interfaces and Lower Critical Dimension in a Spin Glass Model.},\n  author = {Franz, S. and Parisi, G. and Virasoro, M. A.},\n  year = {1994},\n  journal = {Jour. de Phys.},\n  volume = {4}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256198,"version":0,"updated":1753730283776},"$loki":1332},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26608,"entry":"@article{franzMeanFieldGlassy1994,\n  title = {On Mean Field Glassy Dynamics out of Equilibrium},\n  author = {Franz, S. and M{\\'e}zard, M.},\n  year = {1994},\n  journal = {Physica A},\n  volume = {210},\n  pages = {48}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256198,"version":0,"updated":1753730283776},"$loki":1333},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26372,"entry":"@article{franzMeasuringEquilibriumProperties1998,\n  title = {Measuring {{Equilibrium Properties}} in {{Aging Systems}}},\n  author = {Franz, S. and M{\\'e}zard, M. and Parisi, G. and Peliti, L.},\n  year = {1998},\n  journal = {Phys. Rev. Lett.},\n  volume = {81},\n  pages = {1758--1761}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256199,"version":0,"updated":1753730283776},"$loki":1334},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26610,"entry":"@article{franzNonlinearSusceptibilitySupercooled2000,\n  title = {On Non-Linear Susceptibility in Supercooled Liquids},\n  author = {Franz, S. and Parisi, G.},\n  year = {2000},\n  journal = {Journal of Physics: Condensed Matter},\n  volume = {12},\n  pages = {6335},\n  publisher = {{IOP Publishing}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256199,"version":0,"updated":1753730283776},"$loki":1335},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26693,"entry":"@article{franzOverlapInterfacesHierarchical2009