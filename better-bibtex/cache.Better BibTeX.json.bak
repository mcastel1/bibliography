 and {{Random Walks}}},\n  booktitle = {Proc. of 17th {{NIPS}}},\n  author = {Aurell, Erik and Gordon, Uri and Kirkpatrick, Scott},\n  year = {2004},\n  pages = {804}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255879,"version":0,"updated":1753730283776},"$loki":1056},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25878,"entry":"@article{babaConstructionEscherichiaColi2006,\n  title = {Construction of {{{\\emph{E}}}}scherichia Coli {{K-12}} in-Frame, Single-Gene Knockout Mutants: {{The Keio}} Collection},\n  author = {Baba, T. and Ara, T. and Hasegawa, M. and Takai, Y. and Okumura, Y. and Baba, M. and Datsenko, K. A. and Tomita, M. and Wanner, B. L. and Mori, H.},\n  year = {2006},\n  journal = {Mol. Syst. Biol.},\n  volume = {2},\n  number = {1}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255884,"version":0,"updated":1753730283776},"$loki":1057},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26785,"entry":"@article{babuskaFiniteElementMethod1973,\n  title = {The {{Finite Element Method}} with {{Penalty}}},\n  author = {Babuska, Ivo},\n  year = {1973},\n  month = apr,\n  journal = {Mathematics of Computation},\n  volume = {27},\n  number = {122},\n  eprint = {2005611},\n  eprinttype = {jstor},\n  pages = {221},\n  issn = {00255718},\n  doi = {10.2307/2005611},\n  urldate = {2025-05-09},\n  abstract = {An applicationof the penaltymethodto the finiteelementmethodis analyzed. For a model Poisson equationwith homogeneousDirichletboundaryconditions, a variational principlewith penaltyis discussed.This principleleads to the solutionof the Poisson equation by using functionsthat do not satisfy the boundarycondition. The rate of convergenceis discussed.},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/KP6CRCMG/Babuska - 1973 - The Finite Element Method with Penalty.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255886,"version":0,"updated":1753730283776},"$loki":1058},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26235,"entry":"@book{bachmanIntroductionPadicNumbers1964,\n  title = {Introduction to {{P-adic}} Numbers and Valuation Theory},\n  author = {Bachman, G. and {of Mathematics}, Polytechnic Institute of Brooklyn Dept},\n  year = {1964},\n  publisher = {{Academic Press}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255888,"version":0,"updated":1753730283776},"$loki":1059},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26485,"entry":"@article{baillieMonteCarloRenormalizationgroup1992,\n  title = {Monte {{Carlo}} Renormalization-Group Study of the Three-Dimensional {{Ising}} Model},\n  author = {Baillie, C. F. and Gupta, R. and Hawick, K. A. and Pawley, G. S.},\n  year = {1992},\n  journal = {Phys. Rev. B},\n  volume = {45},\n  number = {18},\n  pages = {10438}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255890,"version":0,"updated":1753730283776},"$loki":1060},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26263,"entry":"@article{baity-jesiJanusIINew2014,\n  title = {Janus {{II}}: {{A}} New Generation Application-Driven Computer for Spin-System Simulations},\n  author = {{Baity-Jesi}, M. and Ba{\\~n}os, R. A. and Cruz, A. and Fernandez, L. A. and {Gil-Narvion}, J. M. and {Gordillo-Guerrero}, A. and I{\\~n}iguez, D. and Maiorano, A. and Mantovani, F. and Marinari, E. and {Martin-Mayor}, V. and {Monforte-Garcia}, J. and Sudupe, A. Mu{\\~n}oz and Navarro, D. and Parisi, G. and {Perez-Gaviro}, S. and Pivanti, M. and {Ricci-Tersenghi}, F. and {Ruiz-Lorenzo}, J. J. and Schifano, S. F. and Seoane, B. and Tarancon, A. and Tripiccione, R. and Yllanes, D.},\n  year = {2014},\n  journal = {Comput. Phys. Commun.},\n  volume = {185},\n  number = {2},\n  pages = {550},\n  doi = {10.1016/j.cpc.2013.10.019},\n  abstract = {This paper describes the architecture, the development and the implementation of Janus II, a new generation application-driven number cruncher optimized for Monte Carlo simulations of spin systems (mainly spin glasses). This domain of computational physics is a recognized grand challenge of high-performance computing: the resources necessary to study in detail theoretical models that can make contact with experimental data are by far beyond those available using commodity computer systems. On the other hand, several specific features of the associated algorithms suggest that unconventional computer architectures{\\textendash}that can be implemented with available electronics technologies{\\textendash}may lead to order of magnitude increases in performance, reducing to acceptable values on human scales the time needed to carry out simulation campaigns that would take centuries on commercially available machines. Janus II is one such machine, recently developed and commissioned, that builds upon and improves on the successful JANUS machine, which has been used for physics since 2008 and is still in operation today. This paper describes in detail the motivations behind the project, the computational requirements, the architecture and the implementation of this new machine and compares its expected performances with those of currently available commercial systems.}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534255900,"version":0,"updated":1753730283776},"$loki":1061},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26427,"entry":"@article{baity-jesiMemoryRejuvenationEffects2023g,\n  ti