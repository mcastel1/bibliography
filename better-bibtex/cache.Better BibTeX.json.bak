:{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256484,"version":0,"updated":1753730283776},"$loki":1866},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26550,"entry":"@inproceedings{selmanNoiseStrategiesImproving1994,\n  title = {Noise Strategies for Improving Local Search},\n  booktitle = {Proc. 12th {{AAAI}}},\n  author = {Selman, Bart and Kautz, Henry A. and Cohen, Bram},\n  year = {1994},\n  pages = {337--343},\n  publisher = {{AAAI Press}},\n  address = {{Menlo Park, CA, USA}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256484,"version":0,"updated":1753730283776},"$loki":1867},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25758,"entry":"@article{semerjianApproximationSchemesDynamics2004,\n  title = {Approximation Schemes for the Dynamics of Diluted Spin Models: {{The Ising}} Ferromagnet on a {{Bethe}} Lattice},\n  author = {Semerjian, G. and Weigt, M.},\n  year = {2004},\n  month = may,\n  journal = {Journal of Physics A Mathematical General},\n  volume = {37},\n  pages = {5525--5546},\n  doi = {10.1088/0305-4470/37/21/003}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256485,"version":0,"updated":1753730283776},"$loki":1868},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26639,"entry":"@article{semerjianFreezingVariablesRandom2008,\n  title = {On the Freezing of Variables in Random Constraint Satisfaction Problems},\n  author = {Semerjian, Guilhem},\n  year = {2008},\n  journal = {J. Stat. Phys.},\n  volume = {130},\n  pages = {251}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256486,"version":0,"updated":1753730283776},"$loki":1869},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25681,"entry":"@inproceedings{semerjianStudyPureRandom2004,\n  title = {A {{Study}} of {{Pure Random Walk}} on {{Random Satisfiability Problems}} with ``{{Physical}}'' {{Methods}}},\n  booktitle = {Proceedings of the {{SAT}} 2003 Conference},\n  author = {Semerjian, G. and Monasson, R.},\n  editor = {Giunchiglia, E. and Tachella, A.},\n  year = {2004},\n  series = {Lecture {{Notes}} in {{Computer Science}}},\n  volume = {120},\n  pages = {2919},\n  publisher = {{Springer}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256487,"version":0,"updated":1753730283776},"$loki":1870},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26912,"entry":"@article{senchenko2005shape,\n  title = {Shape and Stability of a Viscous Thread},\n  author = {Senchenko, Sergey and Bohr, Tomas},\n  year = {2005},\n  journal = {Physical Review E{\\textemdash}Statistical, Nonlinear, and Soft Matter Physics},\n  volume = {71},\n  number = {5},\n  pages = {056301},\n  publisher = {{APS}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256490,"version":0,"updated":1753730283776},"$loki":1871},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26726,"entry":"@inproceedings{sengersj.v.etal.PhaseTransitions1980,\n  title = {Phase Transitions},\n  booktitle = {Proceedings of the {{Cargese Summer Institute}}},\n  author = {{Sengers, J. V. et al.}},\n  editor = {{M. L{\\'e}vy, J. C. Le Guillou and J. Zinn-Justin}},\n  year = {1980},\n  publisher = {{Plenum}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256490,"version":0,"updated":1753730283776},"$loki":1872},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26354,"entry":"@article{senoMaximumEntropyApproach2008,\n  title = {Maximum Entropy Approach for Deducing Amino Acid Interactions in Proteins},\n  author = {Seno, F. and Trovato, A. and Banavar, J. R. and Maritan, A.},\n  year = {2008},\n  journal = {Phys. Rev. Lett.},\n  volume = {100},\n  number = {7},\n  pages = {078102}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256491,"version":0,"updated":1753730283776},"$loki":1873},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26120,"entry":"@article{shakhnovichFrozenStatesDisordered1989,\n  title = {Frozen States of a Disordered Globular Heteropolymer},\n  author = {Shakhnovich, E. and Gutin, A. M.},\n  year = {1989},\n  journal = {J. Phys. A: Math. Gen},\n  volume = {22},\n  pages = {1647--1659}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256491,"version":0,"updated":1753730283776},"$loki":1874},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26839,"entry":"@article{shamanskiyMeshMovingTechniques2021,\n  title = {Mesh Moving Techniques in Fluid-Structure Interaction: Robustness, Accumulated Distortion and Computational Efficiency},\n  shorttitle = {Mesh Moving Techniques in Fluid-Structure Interaction},\n  author = {Shamanskiy, Alexander and Simeon, Bernd},\n  year = {2021},\n  month = feb,\n  journal = {Comput Mech},\n  volume = {67},\n  number = {2},\n  pages = {583--600},\n  issn = {0178-7675, 1432-0924},\n  doi = {10.1007/s00466-020-01950-x},\n  urldate = {2025-05-27},\n  abstract = {An important ingredient of any moving-mesh method for fluid-structure interaction (FSI) problems is the mesh moving technique (MMT) used to adapt the computational mesh in the moving fluid domain. An ideal MMT is computationally inexpensive, can handle large mesh motions without inverting mesh elements and can sustain an FSI simulation for extensive periods of time without irreversibly distorting the mesh. Here we compare several commonly used MMTs which are based on the solution of elliptic partial differential equations, including harmonic extension, bi-harmonic extension and techniques based on the equations of linear elasticity. Moreover, we propose a novel MMT which utilizes ideas from continuation methods to efficiently solve the equations of nonlinear elasticity and proves to be robust even when the mesh undergoes extreme motions. In addition to that, we study how each MMT behaves when combined with the mesh-Jacobian-based stiffening. Finally, we evaluate the performance of different MMTs on a popular two-dimensional FSI benchmark reproduced by using an isogeometric partitioned solver with strong coupling.},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/5YQ4W33E/Shamanskiy and Simeon - 2021 - Mesh moving techniques in fluid-structure interact.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256493,"version":0,"updated":1753730283776},"$loki":1875},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25634,"entry":"@article{shannonMathematicalTheoryCommunication1948,\n  title = {A Mathematical Theory of Communication},\n  author = {Shannon, C. E.},\n  year = {1948},\n  journal = {Bell System Tech. J.},\n  volume = {27},\n  pages = {379}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256494,"version":0,"updated":1753730283776},"$loki":1876},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26903,"entry":"@book{shenSpectralMethodsAlgorithms2011,\n  title = {Spectral {{Methods}}: {{Algorithms}}, {{Analysis}} and {{Applications}}},\n  shorttitle = {Spectral {{Methods}}},\n  author = {Shen, Jie and Tang, Tao and Wang, Li-Lian},\n  year = {2011},\n  series = {Springer {{Series}} in {{Computational Mathematics}}},\n  volume = {41},\n  publisher = {{Springer Berlin Heidelberg}},\n  address = {{Berlin, Heidelberg}},\n  doi = {10.1007/978-3-540-71041-7},\n  urldate = {2025-06-17},\n  copyright = {https://www.springernature.com/gp/researchers/text-and-data-mining},\n  isbn = {978-3-540-71040-0 978-3-540-71041-7},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/K8U5MSSD/Shen et al. - 2011 - Spectral Methods Algorithms, Analysis and Applica.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256494,"version":0,"updated":1753730283776},"$loki":1877},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26874,"entry":"@article{simonActinDynamicsDrive2019,\n  title = {Actin Dynamics Drive Cell-like Membrane Deformation},\n  author = {Simon, Camille and Kusters, R{\\'e}my and Caorsi, Valentina and Allard, Antoine and {Abou-Ghali}, Majdouline and Manzi, John and Di Cicco, Aur{\\'e}lie and L{\\'e}vy, Daniel and Lenz, Martin and Joanny, Jean-Fran{\\c c}ois and Campillo, Cl{\\'e}ment and Plastino, Julie and Sens, Pierre and Sykes, C{\\'e}cile},\n  year = {2019},\n  month = jun,\n  journal = {Nat. Phys.},\n  volume = {15},\n  number = {6},\n  pages = {602--609},\n  issn = {1745-2473, 1745-2481},\n  doi = {10.1038/s41567-019-0464-1},\n  urldate = {2025-06-15},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/59CYYJMP/Simon et al. - 2019 - Actin dynamics drive cell-like membrane deformatio.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256494,"version":0,"updated":1753730283776},"$loki":1878},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26036,"entry":"@article{simoneExactGroundStates1996,\n  title = {Exact {{Ground States}} of {{Two-Dimensional}} +/-{{J Ising Spin Glasses}}},\n  author = {{de Simone}, C. and Diehl, M. and Junger, M. and Mutzel, P. and Reinelt, G. and Rinaldi, G.},\n  year = {1996},\n  journal = {J. Stat. Phys.},\n  volume = {84},\n  pages = {1363--1371}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256495,"version":0,"updated":1753730283776},"$loki":1879},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25716,"entry":"@book{sinclairAlgorithmsRandomGeneration1993,\n  title = {Algorithms for {{Random Generation}} and {{Counting}}: {{A Markov Chain Approach}}},\n  author = {Sinclair, A.},\n  year = {1993},\n  publisher = {{Birkha{\\\"u}ser}},\n  address = {{Boston-Basel-Berlin}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256496,"version":0,"updated":1753730283776},"$loki":1880},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26507,"entry":"@article{singMultiplebindingsiteMechanismExplains2014,\n  title = {Multiple-Binding-Site Mechanism Explains Concentration-Dependent Unbinding Rates of {{DNA-binding}} Proteins},\n  author = {Sing, C. E. and {de la Cruz}, M. O. and Marko, J. F.},\n  year = {2014},\n  journal = {Nucl. Acids. Res.},\n  volume = {42},\n  number = {6},\n  pages = {3783}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256496,"version":0,"updated":1753730283776},"$loki":1881},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26830,"entry":"@article{sischkaInfluenceHigherOrder2025,\n  title = {The Influence of Higher Order Geometric Terms on the Asymmetry and Dynamics of Membranes},\n  author = {Sischka, Jan Magnus and Nitschke, Ingo and Voigt, Axel},\n  year = {2025},\n  journal = {Faraday Discuss.},\n  pages = {10.1039.D4FD00202D},\n  issn = {1359-6640, 1364-5498},\n  doi = {10.1039/D4FD00202D},\n  urldate = {2025-05-22},\n  abstract = {Rapid shape changes of cells are facilitated by membrane viscosity and higher order geometric terms.           ,              We consider membranes as fluid deformable surfaces and allow for higher order geometric terms in the bending energy related to the Gaussian curvature squared and the mean curvature minus the spontaneous curvature to the fourth power. The evolution equations are derived and numerically solved using surface finite elements. The two higher order geometric terms have different effects. While the Gaussian curvature squared term has a tendency to stabilize tubes and enhance the evolution towards equilibrium shapes, thereby facilitating rapid shape changes, the mean curvature minus the spontaneous curvature to the fourth power destabilizes tubes and leads to qualitatively different equilibrium shapes but also enhances the evolution. This is demonstrated in axisymmetric settings and fully three-dimensional simulations. We therefore postulate that not only surface viscosity but also higher order geometric terms in the bending energy contribute to rapid shape changes which are relevant for morphological changes of cells.},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/FMRNRZ9M/Sischka et al. - 2025 - The influence of higher order geometric terms on t.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256497,"version":0,"updated":1753730283776},"$loki":1882},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25775,"entry":"@article{skantzosAverageReliabilityError2003,\n  title = {Average and Reliability Error Exponents in Low-Density Parity-Check Codes},\n  author = {Skantzos, N. S. and {van Mourik}, J. and Saad, D. and Kabashima, Y.},\n  year = {2003},\n  journal = {J. Phys. A},\n  volume = {36},\n  pages = {11131--11141}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256497,"version":0,"updated":1753730283776},"$loki":1883},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25877,"entry":"@article{slaterConstructionApproximateEntropic1994,\n  title = {Construction of Approximate Entropic Forces for Finitely Extensible Nonlinear Elastic ({{FENE}}) Polymers},\n  author = {Slater, G. W. and Hubert, S. J. and Nixon, G. I.},\n  year = {1994},\n  journal = {Macromol. Theor. Simul.},\n  volume = {3},\n  number = {4},\n  pages = {695}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256497,"version":0,"updated":1753730283776},"$loki":1884},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26909,"entry":"@book{slaughterLinearizedTheoryElasticity2002,\n  title = {The {{Linearized Theory}} of {{Elasticity}}},\n  author = {Slaughter, William S.},\n  year = {2002},\n  publisher = {{Birkh{\\\"a}user Boston}},\n  address = {{Boston, MA}},\n  doi = {10.1007/978-1-4612-0093-2},\n  urldate = {2025-06-24},\n  copyright = {http://www.springer.com/tdm},\n  isbn = {978-1-4612-6608-2 978-1-4612-0093-2},\n  langid = {english},\n  file = {/Users/michelecastellana/Zotero/storage/CMZ4EWNW/Slaughter - 2002 - The Linearized Theory of Elasticity.pdf}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256498,"version":0,"updated":1753730283776},"$loki":1885},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25828,"entry":"@article{smithCharacterizationEnzymeComplex1980,\n  title = {Characterization of the Enzyme Complex Involving the Folate-Requiring Enzymes of de Novo Purine Biosynthesis},\n  author = {Smith, G. K. and Mueller, W. T. and Wasserman, G. F. and Taylor, W. D. and Benkovic, S. J.},\n  year = {1980},\n  journal = {Biochemistry-US},\n  volume = {19},\n  number = {18},\n  pages = {4313}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256498,"version":0,"updated":1753730283776},"$loki":1886},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25962,"entry":"@article{smoluchowskiDreiVortrageUber1916,\n  title = {Drei {{Vortrage}} Uber {{Diffusion}}, {{Brownsche Bewegung}} Und {{Koagulation}} von {{Kolloidteilchen}}},\n  author = {Smoluchowski, M. V.},\n  year = {1916},\n  journal = {Zeitschrift f{\\\"u}r Physik},\n  volume = {17},\n  pages = {557}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256498,"version":0,"updated":1753730283776},"$loki":1887},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26595,"entry":"@book{soberOckhamRazorsUser2015,\n  title = {Ockham's {{Razors}}: {{A User}}'s {{Manual}}},\n  author = {Sober, E.},\n  year = {2015},\n  publisher = {{Cambridge University Press}}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256499,"version":0,"updated":1753730283776},"$loki":1888},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":25966,"entry":"@article{sompolinskiDynamicTheoryIsing1981,\n  title = {Dynamic {{Theory}} of the {{Ising Spin-Glass Phase}}},\n  author = {Sompolinski, H. and Zippelius, A.},\n  year = {1981},\n  journal = {Phys. Rev. Lett.},\n  volume = {47},\n  pages = {359--362}\n}\n","metadata":{"DeclarePrefChars":"","noopsort":false,"packages":[]},"meta":{"revision":0,"created":1751534256499,"version":0,"updated":1753730283776},"$loki":1889},{"exportNotes":false,"useJournalAbbreviation":true,"bibtexURL":"off","DOIandURL":"both","itemID":26086,"entry":"@article{sompolinskiFluctuationsShortRangeSpinGlasses1983,\n  