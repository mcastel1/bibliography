  shorttitle = {The {{HIV}} Lipidome},
  author = {Br{\"u}gger, Britta and Glass, B{\"a}rbel and Haberkant, Per and Leibrecht, Iris and Wieland, Felix T. and Kr{\"a}usslich, Hans-Georg},
  year = 2006,
