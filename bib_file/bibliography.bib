@article{tutkusFluorescenceMicroscopySingle2018,
  title = {Fluorescence {{Microscopy}} of {{Single Liposomes}} with {{Incorporated Pigment}}--{{Proteins}}},
  author = {Tutkus, Marijonas and Akhtar, Parveen and Chmeliov, Jevgenij and G{\"o}rf{\"o}l, Fanni and Trinkunas, Gediminas and Lambrev, Petar H. and Valkunas, Leonas},
  year = 2018,
