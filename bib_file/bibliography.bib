@article{cannellaMagneticSusceptibilityAu1971,
  title = {Magnetic {{Susceptibility}} of {{Au}}--{{Fe Alloys}}},
  author = {Cannella, V. and Mydosh, J. A. and Budnick, J. I.},
  year = 1971,
  journal = {Journal of Applied Physics},
  volume = {42},
  number = {4},
  pages = {1689},
  abstract = {Over the past years there has been considerable interest in the magnetic properties of the Au(Fe) system. M\"ossbauer measurements indicate that a complicated type of long-range ordering occurs below concentrations c of {$\sim$}12 at.\% Fe and extends down to c\&lt;1\%. Yet no definitive susceptibility study has been carried out over a complete range of temperatures and concentrations in order to characterize the magnetic ordering. We have measured the low-field magnetic susceptibility {$\chi$}(T) for a series of eight Au--Fe alloys (1--22 at.\% Fe), and we observe a definite peak in {$\chi$} at those ordering temperatures determined from the M\"ossbauer data. The magnitude of {$\chi$} greatly increases with c, while the shape of {$\chi$}(T) in the region of the peak changes from a cusp-like behavior at low c to a behavior for c{$\greaterequivlnt$}17\% in which {$\chi$}(T) gently rises, then sharply falls. These behaviors confirm the existence of a long-range order suggtesive of antiferromagnetism at low c ({$\leq$}8\%) with a more typical ferromagnetic ordering at high c. At intermediate c ({$\approx$}12\%), {$\chi$}(T) seems to indicate the presence of a mixed type of long-range order.}
}

