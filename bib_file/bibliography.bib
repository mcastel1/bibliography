@article{bansalNitscheMethodNavier2024,
  title = {Nitsche Method for {{Navier}}--{{Stokes}} Equations with Slip Boundary Conditions: {{Convergence}} Analysis and {{VMS-LES}} Stabilization},
  shorttitle = {Nitsche Method for {{Navier}}--{{Stokes}} Equations with Slip Boundary Conditions},
  author = {Bansal, Aparna and Barnafi, Nicol{\'a}s A. and Pandey, Dwijendra Narain},
  year = 2024,
  month = sep,
  journal = {ESAIM: M2AN},
  volume = {58},
  number = {5},
  pages = {2079--2115},
  issn = {2822-7840, 2804-7214},
  doi = {10.1051/m2an/2024070},
  urldate = {2024-11-18},
  abstract = {In this paper, we analyze Nitsche's method for the stationary Navier--Stokes equations on Lipschitz domains under minimal regularity assumptions. Our analysis provides a robust formulation for implementing slip ( i.e ., Navier) boundary conditions in arbitrarily complex boundaries. The well-posedness of the discrete problem is established using the Banach Ne\v cas--Babu\v ska and Banach fixed point theorems under standard small data assumptions. We also provide optimal convergence rates for the approximation error. Furthermore, we propose a quasi-static VMS-LES formulation with Nitsche for the Navier--Stokes equations with slip boundary conditions to address the simulation of incompressible fluids at high Reynolds numbers. We validate our theory through several numerical tests in well-established benchmark problems.},
  file = {/Users/michelecastellana/Zotero/storage/BAQ75E9P/Bansal et al. - 2024 - Nitsche method for Navier–Stokes equations with slip boundary conditions convergence analysis and V.pdf}
}

